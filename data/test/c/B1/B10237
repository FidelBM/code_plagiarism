typedef vector<string> strarr;

class FileIO
{
	ifstream	fin;
	ofstream	fout;
	string		name;

public:
	void read(strarr& line, const char* fname)
	{
		name = fname;
		if(fin.is_open())
			fin.close();
		fin.open(fname, ios::binary);
		line.clear();
#define MAX_BUFFER 1024
		while(!fin.eof())
		{
			char buffer[MAX_BUFFER];
			fin.getline(buffer, MAX_BUFFER);
			if(*buffer != ' ' && *buffer != '\n' && *buffer != '\0')
			{
				line.push_back(string(buffer));
			}
		}
		fin.close();
	}

	void write(vector<string>& data)
	{
		if(fout.is_open())
			fout.close();
		string new_name(name);
		new_name += "out";
		fout.open(new_name.c_str(), ios::binary);
		string out;
		for(int i=0 ; i<data.size() ; i++)
		{
			fout.write(data[i].c_str(), data[i].length());
			fout<<"\n";
			//out.append(data[i]);
			//out.push_back('\n');
			//fout.write(data[i].c_str(), data[i].length());
			//fout<<'\n';
		}
		fout.close();
	}
};

