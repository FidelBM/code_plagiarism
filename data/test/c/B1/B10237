class Tokenizer
{
public:
	void tokenize(strarr& tokens, const string& str)
	{
		const char *ptr, *start;
		start = ptr = str.c_str();
		for(string::size_type i=0 ; ; i++,ptr++)
		{
			char c = *ptr;
			if(c == ' ' || c == '\t')
			{
				tokens.push_back(string(start,ptr-start));
				start = ptr+1;
			}
			else
			if(c == '\n')
			{
				tokens.push_back(string(start,ptr-start-1));
				break;
			}
			else
			if(c == '\0')
			{
				tokens.push_back(string(start,ptr-start));
				break;
			}
			else
			{	continue;}
		}
	}
};

