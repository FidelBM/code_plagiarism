#include<iostream>
#include<sstream>
#include<string>
#include<set>
using namespace std;
string toStr(int n)
{
    stringstream ss("");
    ss<<n;
    string str;
    ss>>str;
    return str;
}
int toInt(string str)
{
    stringstream ss("");
    ss<<str;
    int n;
    ss>>n;
    return n;
}
int main()
{
    int t;
    cin>>t;
    for(int z=1;z<=t;z++)
    {
        int count=0;
        int a,b;
        cin>>a>>b;
        for(int curr=a;curr<=b;curr++)
        {
            string str=toStr(curr);
            int len=str.length();
            //cout<<"*"<<str<<endl;
            set<int> nums;
            for(int i=1;i<len;i++)
            {
                int x=0;
                for(int j=i;;)
                {
                    //cout<<str[j];
                    x=x*10+str[j]-'0';
                    j=(j+1)%len;
                    if(j==i)
                    break;
                }
                //cout<<endl;
                //cout<<x<<endl;
                if(x>curr && x<=b)
                nums.insert(x);
            }
            count+=nums.size();
        }
        cout<<"Case #"<<z<<": "<<count<<endl;
    }

    return 0;
}
