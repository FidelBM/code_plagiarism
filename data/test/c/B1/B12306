set<int> rpair(int x) {
	set<int> p;

	int digit = 0;
	int mult = 1;
	while (mult <= x) {
		digit++;
		mult *= 10;
	}
	int y = pow(10, digit - 1);

	for (int i = 0; i < digit - 1; i++) {
		x = (x / 10) + (x % 10) * y;
		(p).insert(x);
	}

	return p;
}

int main() {
	freopen("B-small.in", "r", stdin);
	freopen("B-small.out", "w", stdout);

	int t;
	scanf("%d\n", &t);

	for (int i = 1; i <= t; i++) {
		int a, b;
		scanf("%d %d\n", &a, &b);
		int ans = 0;
		for (int j = a; j <= b; j++) {
			set<int> p = rpair(j);
			for (set<int>::iterator itr = p.begin(); itr != p.end(); itr++) {
				if (j < *itr && *itr <= b) ans++;
			}
		}

		printf("Case #%d: %d\n", i, ans);
	}

	return 0;
}
