#include <iostream>
#include <cstdio>

using namespace std;
int bit[32];

int main()
{
freopen("C-small-attempt0.in","r",stdin);
freopen("C-small-attempt0.out","w",stdout);
int ca,A,B,ans,cas=1;
cin>>ca;
while(ca--)
{
cin>>A>>B;
ans=0;
for(int i=A;i<=B;i++)
{
int cnt=0,tmp=i;
while(tmp)
{
bit[cnt++]=tmp%10;
tmp/=10;
}
int tmp1=i,tmp2=0;
for(int j=0;j<cnt-1;j++)
if(bit[j]!=0)
{
tmp1=tmp2=0;
for(int k=j;k>=0;k--)
tmp2=tmp2*10+bit[k];
for(int k=cnt-1;k>j;k--)
{
tmp2*=10;
tmp1=tmp1*10+bit[k];
}
// cout<<i<<" "<<tmp1+tmp2<<endl;
if(tmp1+tmp2>=A&&tmp2+tmp1<=B&&tmp1+tmp2!=i) ans++;
}
}
printf("Case #%d: %d\n",cas++,ans/2);
}
return 0;
}
