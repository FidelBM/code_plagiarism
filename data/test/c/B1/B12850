#include <iostream>
#include <math.h>

using namespace std;

bool recycled (unsigned long m,unsigned long n)
{
	if (m<10) return false;
	int len=max<unsigned long>(ceil(log10((float)m)),ceil(log10((float)n)));
	
	int factor=1;
	int i=len-1;
	while (i--) factor*=10;
	i=len;
	while (i--)
	{
		int k=n%10;
		n/=10;
		n=n+k*factor;
		if (n==m) return true;
	};
	return false;
};

