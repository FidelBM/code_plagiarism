const int inf = 1000 * 1000 * 1000, max_a = 2000000 + 41;
vector <int> g[max_a];

int to_int (string& s) {
    int res = 0;
    for (int i = 0; i < s.length(); i++)
        res = res * 10 + s[i] - '0';
    return res;
}

string to_str (int x) {
       string res = "";
       while (x > 0)
             res += (x % 10 + '0'), x /= 10;
       reverse(res.begin(), res.end());
       return res;
}

int x[41], sz = 0;

int min_shift(int i)
{
    string s = to_str(i);
    int n = s.length();
    sz = 0;
    for (int i = 0; i < n; i++) {
        if (s[0] != '0') x[sz++] = to_int(s);
        char temp = s[0];
        for (int j = 0; j < n - 1; j++)
            s[j] = s[j + 1];
        s[n - 1] = temp;
    }
    int res = inf;
    for (int i = 0; i < sz; i++)
        res = min(res, x[i]);
    return res;
}

