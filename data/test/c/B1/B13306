#include <cstdlib>
#include <cstdio>
#include <memory.h>
#include <cstring>

bool done[20001], tdone[20001];
char b1[11], b2[11];
int a, b;
int ll;

int check(int n) {
	itoa(n, b1, 10);
	int res = 0;
	memset(tdone, 0, sizeof(tdone));
	
	for(int i=1; i<ll; ++i) {
		memcpy(b2, &b1[ll-i], i*sizeof(char));
		memcpy(&b2[i], b1, (ll-i)*sizeof(char));

		int nn = atoi(b2);
		if(nn>=a && nn<=b && !tdone[nn] && !done[nn]) {
			tdone[nn] = true;
			res++;
		}
	}

	return res;
}

int main(int argc, char **argv) {

	int nbTests;
	int res;
	
	scanf("%d", &nbTests);

	for(int n=1; n<=nbTests; ++n) {
		res = 0;
		memset(done, 0, sizeof(done));
		memset(b1, 0, sizeof(b1));
		memset(b2, 0, sizeof(b2));
		scanf("%d%d", &a, &b);
		itoa(a, b1, 10);
		ll = strlen(b1);

		//for(int i=a, s=(b-a)/2+a; i<=s; ++i) {
		for(int i=a, s=b; i<=s; ++i) {
			if(!done[i]) {
				done[i] = true;
				res += check(i);
			}
		}

		printf("Case #%d: %d\n", n, res);
	}

	return 0;
}
