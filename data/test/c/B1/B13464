#include "Solution.hpp"

#include <boost/cstdint.hpp>

#include <sstream>
#include <set>

//-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾
namespace GCJFramework {
//-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾-‾
bool
Solution::execute(std::istream& _inputStream, std::ostream& _outputStream) const
{
    boost::uint32_t testCases;

    _inputStream >> testCases;

    for (boost::uint32_t i = 0; i < testCases; ++i)
    {
        std::stringstream stream;
        int numRecycledPairs = 0;
        int rangeStart, rangeEnd;
        _inputStream >> rangeStart >> rangeEnd;

        while (rangeStart <= rangeEnd)
        {
            std::stringstream firstNumber;
            firstNumber << rangeStart;
            int strLen = firstNumber.str().size();
            if (strLen > 1)
            {
                std::set<int> detected;
                for (int i = 1; i < strLen; i++)
                {
                    std::stringstream secondNumber, test;
                    secondNumber << firstNumber.str().substr(i)
                                 << firstNumber.str().substr(0,i);
                    int value;
                    secondNumber >> value;
                    test << value;
                    if (detected.find(value) == detected.end() &&
                        test.str().size() == strLen && 
                        value > rangeStart && 
                        value <= rangeEnd)
                    {
                        detected.insert(value);
                        numRecycledPairs++;
                    }
                }
            }
            rangeStart++;
        }

        stream << "Case #" << i+1 << ": " << numRecycledPairs << std::endl;
        _outputStream << stream.str();
    }

    return true;
}

