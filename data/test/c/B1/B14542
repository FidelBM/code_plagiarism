
//Boost libraries are available at http://www.boost.org/.
#include <boost/cstdint.hpp>
typedef boost::int64_t Int;

#include <iostream>
using std::cin;
using std::cout;
using std::endl;


int main(int argc, char** argv)
{
    int T;
    cin >> T;

    for (int testcase = 1; testcase <= 20; ++testcase) {
        cout << "--" << endl;
        Int N, P1, W1, M, K, A, B, C, D;
        cin >> N >> P1 >> W1 >> M >> K >> A >> B >> C >> D;
        if (testcase <= T) {
            cout << testcase << endl;
            for (int i = 1; i < testcase; ++i) {
                cout << "1 1 1 1 1 1 1 1 1\n";
            }
            cout << N << " " << P1 << " " << W1 << " " << M << " " << K << " " << A << " " << B << " " << C << " " << D << endl;
        } else {
            cout << 0 << endl;
        }
    }
}

