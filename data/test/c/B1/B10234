int Algo::cycle(int n)
{
    int nbD = 0;
    float nfl = n;
    int p=1;


    nbD++;
    nfl/=10;
    while(nfl>=1)
    {
        p*=10;
        nbD++;
        nfl/=10;
    }
    int r;
    do{
        r = n%10;
        n=(int)((n-r)/10);
    }while(r==0);
    //qDebug()<<n<<" => : "<<(((int)((n-r)/10))+r*p);


    return n+r*p;
}
