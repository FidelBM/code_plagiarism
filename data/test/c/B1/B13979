using namespace std;

int toInt(char * array)
{
    int result= 0;
    int length = 0;
    int mul = 1;
  while(array[length++] != '\0');
  length--;
  
  for(int k = length-1 ; k >= 0 ; k--)
  {
    result += mul*(array[k]-48);
    mul*= 10;
    
  }

  return result;
}

char * toStr(int num)
{
  char * list = new char[40];
  int number = 0 ;
  int index = 0;
  while (num != 0)
  {
    (number = num%10);
    list[index++]=number+48;
    num /= 10;
   }
   
  char * result = new char[40];
  
  for(int k = 0 ; k < index ; k++)
  result[index-k-1] = list[k];
   
   delete [] list;
   
  result[index] = '\0'; 
  return result;
}



