#include<stdio.h>
#include<iostream>
#include<string.h>
#include<ctype.h>
#include<math.h>
#include<map>
using namespace std;

int main()
{
    FILE *in = fopen("C-small-attempt0.in","r");
    FILE *out = fopen("C_out.txt","w");

    int n,a,b,temp;
    map<int,int> m;
    fscanf(in,"%d\n",&n);

    for(int Case=1; Case<=n; Case++){
        fprintf(out,"Case #%d: ",Case);

        fscanf(in,"%d %d\n",&a,&b);
        printf("a:%d   b:%d\n",a,b);
        int len = 1;
        temp = a;
        while((temp/10)!=0){
            len++;
            temp /= 10;
        }
        printf("len : %d\n",len);
        int now = a;
        int ans = 0;
        m.clear();
        
        while(1)
        {
            temp = now;
            //m[now]=1;
           // printf("temp:%d\n",temp);
            
            int divi = 1;(int)pow(10,len-1);
            int x = 1;
            
            for(int i=0;i<len-1;i++)
                divi *= 10;
            for(int i=0;i<len;i++)
                x *= 10;            
           // printf("x: %d   divi:%d\n",x,divi);
            
            for(int i=0;i<len;i++){
               
                
                int left = temp/divi;
                temp *= 10;
                //printf("%d  %d \n",temp,left);
                temp += left;
               // printf("%d  %d \n",temp,left);
                temp = temp % x;
               // printf("%d  %d \n",temp,left);
                if(temp>=a && temp<=b && now<temp && m[now*x + temp]==0)
                {
                    m[now*x + temp]=1;
                    ans++;
                    //printf("now : %d   ans : %d\n",now,temp);
                }
            }
           // system("pause");
            if(now==b)
                break;
            now++;
        }//system("pause");
        fprintf(out,"%d\n",ans);
    }
//scanf("1");
    return 0;
}
