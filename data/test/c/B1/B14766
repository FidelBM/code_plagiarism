#include<vector>
#include<iostream>
#include<cmath>
using namespace std;
int countdig(int num){
	int dig=0;
	while(num!=0){
		dig++;
		num/=10;
	}
	return dig;
}
int shift(int num,int digit,int places){
	int newnum=0;
	if(num%(int)pow(10,places)==0) return num;
	for(int i=0;i<places;i++){
		int last=num%10;
		newnum=last*pow(10,digit-1)+num/10;
		num=newnum;
	}
	//cout<<newnum<<endl;
	return newnum;
}
int main(){
	int t;
	cin>>t;
	for(int i=1;i<=t;i++){
	vector < vector<bool> > saved(10000,vector<bool> (10000,false));
		int a,b;
		int count=0;
		cin>>a>>b;
		int dig=countdig(a);
		for(int j=a;j<=b;j++){
			for(int k=1;k<=dig;k++){
				int shiftednum=shift(j,dig,k);
				if(dig==countdig(shiftednum)&&shiftednum<=b&&shiftednum>j&&saved[j][shiftednum]==false){
					count++;
					saved[j][shiftednum]=true;	
				}
			}	
		}
		cout<<"Case #"<<i<<": "<<count<<endl;
	}
	return 0;
}
