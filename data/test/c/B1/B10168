multimap<int,int> refMap;

bool checkValue(int k, int v){
    if (refMap.count(k) <= 0)
        return false;
    else{
        multimap<int,int>::const_iterator it;
        pair<multimap<int,int>::iterator, multimap<int,int>::iterator> ii;
        ii = refMap.equal_range(k);
        for(it = ii.first; it != ii.second; ++it){
            if(it->second == v)
                return true;
        }
    }

    return false;
}

bool checkMap(int k, int v){
    if( k == v)
        return true;

    if (checkValue(k,v))
        return true;
    else if (checkValue(v,k))
        return true;
    else
        return false;
}

int getDigits(int n){
    if (n <= 9)
        return 1;
    else if((n/10) <10)
        return 2;
    else if((n/10) <100)
        return 3;
    else if((n/10) <1000)
        return 4;
    else if((n/10) <10000)
        return 5;
    else if((n/10) <100000)
        return 6;
    else if((n/10) <1000000)
        return 7;
    else
        return 0;
}

int getX(int n, int digits){
    switch(digits){
        case 2:
            n = n*10;
            break;
        case 3:
            n = n*100;
            break;
        case 4:
            n = n*1000;
            break;
        case 5:
            n = n*10000;
            break;
        case 6:
            n = n*100000;
            break;
        case 7:
            n = n*1000000;
            break;
        default:
            n = 0;
    }
    return n;
}

int getY(int digits){
    int n = 0;
    switch(digits){
        case 2:
            n = 11;
            break;
        case 3:
            n = 111;
            break;
        case 4:
            n = 1111;
            break;
        case 5:
            n = 11111;
            break;
        case 6:
            n = 111111;
            break;
        case 7:
            n = 1111111;
            break;
        default:
            n = 1;
    }
    return n;
}

int shiftDigit(int n, int digits){
    int last_d = n%10;
    int d = n/10;
    return getX(last_d,digits)+d;
}

