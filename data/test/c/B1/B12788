#include <iostream>
#include <sstream>

using namespace std;

bool isrecycle(int i, int j){
  int tmpj = j;
  int mul = 1;
  while(tmpj >= 10){
    mul *= 10;
    tmpj /= 10;
  }
  tmpj = j;
  do{
    if(i == tmpj) return true;
    tmpj = tmpj % 10 * mul + tmpj / 10;
  }while(j != tmpj);
  return false;
}

int main(void){
  int t, a, b;
  cin >> t;
  for(int k = 0; k < t; ++k){
    cin >> a >> b;
    int cnt = 0;
    for(int i = a; i <= b; ++i)
      for(int j = i+1; j <= b; ++j)
        if(isrecycle(i, j))
          ++cnt;
    cout << "Case #" << k+1 << ": " << cnt << endl;
  }
}
