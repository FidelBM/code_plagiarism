#include <iostream>
#include <string>
#include <set>

using namespace std;

string intToStr(int x) {
    string ans = "";
    while (x) {
        ans = (char)('0' + x % 10) + ans;
        x /= 10;
    }
    return ans;        
}

int strToInt(string s) {
    int ans = 0;
    for (size_t index = 0; index < s.length(); ++index) 
        ans = 10 * ans + (s[index] - '0');
    return ans;
}

int calc(int A, int B) {
    int ans = 0;
    for (int m = A + 1; m <= B; ++m) {
        set<int> numbers;
        string s = intToStr(m);
        for (size_t jndex = 0; jndex < s.length(); ++jndex) {
            char c = s[0];
            s = s.substr(1);
            s += c;
            int t = strToInt(s);
            if (t >= A && t <= B && t < m)
                numbers.insert(t);
        }
        ans += numbers.size();
    }
    return ans;
}

int main() {
    int testsCount;
    cin >> testsCount;
    for (size_t test = 1; test <= testsCount; ++test) {
        int A, B;
        cin >> A >> B;
        cout << "Case #" << test << ": " << calc(A, B) << endl;
    }
    return 0;
}
