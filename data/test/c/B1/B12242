#define sz size()
#define all(x) (x).begin(),(x).end()
#define pb push_back
#define mp make_pair
#define X first
#define Y second
#define sqr(x) ((x)*(x))

vector<vector<int> > ans;

int len(int n) {
	return ceil(log(n + .0) / log(10.0));
}

void rec(int num) {
	int lenNum = len(num), next = num, pow = 1;
	
	for(int i = 1; i < lenNum; i++) {
		pow *= 10;
	}

	for(int i = 0; i < lenNum; i++) {
		next = (next % 10) * pow + (next / 10);
		if(next != num) {
			ans[num].pb(next);
		}
	}
}
void init(int maxn) {
	ans.resize(maxn + 1);
	for(int i = 0; i <= maxn; i++) {
		rec(i);
	}
}

int solve(int l, int r) {
	set<pair<int,int> > t;
	for(int i = l; i <= r; i++) {
		for(int j = 0; j < ans[i].sz; j++) {
			if(ans[i][j] >= l && ans[i][j] <= r) {
				t.insert(mp(min(i, ans[i][j]), max(i, ans[i][j])));
			}
		}
	}

	return t.sz;
}
int main() {
	freopen("output.txt", "w", stdout);
	init(1500);
	int t, a, b;
	cin >> t;
	for(int i = 1; i <= t; i++) { 
		cin >> a >> b;
		printf("Case #%d: %d\n", i, solve(a, b));
	}
