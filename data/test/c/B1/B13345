string conv(int i)
{
    string s = "";
    while (i > 0) {
        s += char(i % 10 + '0');
        i /= 10;
    }
    return s;
}

int cycle(int i, int j)
{
    string s = conv(i);
    string u = conv(j);

    for (int i = 1; i < sz(s); ++i)
        if (s.substr(i) + s.substr(0, i) == u)
            return 1;
    return 0;
}

int main()
{
    freopen("C-small-attempt0.in", "r", stdin);
    freopen("C-small-attempt0.out", "w", stdout);

    int cases;
    cin >> cases;
    for (int c = 1; c <= cases; ++c) {
        int A, B;
        cin >> A >> B;

        int cnt = 0;
        for (int i = A; i <= B; ++i)
            for (int j = i + 1; j <= B; ++j)
                if (cycle(i, j))
                    ++cnt;

        cout << "Case #" << c << ": " << cnt << endl;
    }

    return 0;
}
