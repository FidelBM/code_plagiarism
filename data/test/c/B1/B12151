#include <cstdlib>
#include <iostream>
#include <math.h>
#include <fstream>
using namespace std;

int test,a,b;

int solve(int a,int b){
    int c,res=0;
    if(a==1000)
    a-=1;
  if(a/10==0)
  return 0;
  else{
    for(int i=a;i<=b;i++){
      if((int)log10(i)==1){
        c=(i%10)*10+i/10;
        if(c>i&&c<=b&&c>=a)
        res++;                
      }
      else
        if((int)log10(i)==2){
          c=(i%10)*100+i/10;
          if(c>i&&c<=b&&c>=a)
          res++;
          c=(i%100)*10+i/100;
          if(c>i&&c<=b&&c>=a)
          res++;
                           
        }      
    } 
    return res;    
  }     
}

void input(){

     
      ifstream cin("B-small.in");
      ofstream cout("B-small.out");
      
     cin>>test;
     for(int i=1;i<=test;i++){
        cin>>a>>b;
      cout<<"Case #"<<i<<": "<<solve(a,b)<<endl;          
     }     
}

int main(int argc, char *argv[])
{
    input();
    
    system("PAUSE");
    return EXIT_SUCCESS;
}
