int tc, a, b;

string sub(string str, int a, int b) {
	string ret = "";
	FOR(i, a, b)
		ret += str[i];
	return ret;
}

bool is_recycled_pair(int m, int n) {
	stringstream sin;
	sin << m;
	string a;
	sin >> a;
	
	stringstream ssin;
	ssin << n;
	string b;
	ssin >> b;
	
	
	if (a.length() != b.length()) {
		return 0;
	}
	
	int len = a.length();
	
	for (int i = 0; i < len - 1; i++) {
		string x = sub(a, i + 1, len - 1) + sub(a, 0, i);
		//cout << "X = " << x << endl;
		if (x == b)
			return 1;
	}
	return 0;
}


int main () {
	
	//cout << is_recycled_pair(12345, 34512) << endl;
	
	scanf("%d", &tc);
	
	int ans = 0;
	
	FOR(i, 1, tc) {
		scanf("%d %d", &a, &b);
		ans = 0;
		FOR(j, a, b) {
			FOR(k, j + 1, b) {
				if (is_recycled_pair(j, k))
					ans++;
			}
		}
		
		printf("Case #%d: %d\n", i, ans);
	}
	
}
