#include <cstring>
#include <iostream>
#include <map>
#include <cstdio>
#include <set>
#include <iterator>
using namespace std;

int A,B;

int getBit(int a)
{
    int t = 0;
    while(a !=0 )
    {
        t++;
        a/=10;
    }
    return a;
}

string intToString(int a)
{
    string s = "";
    while(a)
    {
        s += (a%10+'0');
        a /= 10;
    }
    reverse(s.begin(), s.end());
    return s;
}

int po[10]={1,10,100,1000,10000};

int stringToInt(string s)
{
    int l = s.size();
    int t = 0;
    for(int i=0;i<l;++i)
    {
        t+=(s[i]-'0')*po[l-1-i];
    }
    return t;
}

int getInt(int a)
{
    int re = 0;
    string str1 = intToString(a);
    int l1 = str1.size();
    set<string> s;
    for(int i = 0; i < l1; ++i)
    {
        string ss = "";
        for(int j=i; j<l1;++j) ss+=str1[j];
        for(int j=0; j<i; ++j) ss+=str1[j];
        s.insert(ss);
    }
    set<string>::iterator it = s.begin();
    for(; it != s.end();++it)
    {
        int num = stringToInt(*it);
        if(num > a && num <= B)
          re++;
    }
    return re;
}

int main()
{
    freopen("C-small-attempt0.in","r", stdin);
    freopen("C-small-attempt0.out","w", stdout);
    int t;
    cin >> t;
    int ca = 0;
    while(t--)
    {
        cin >> A >> B;
        int sum = 0;
        for(int i = A; i <= B; ++i)
        {
            sum += getInt(i);
        }
        printf("Case #%d: ", ++ca);
        cout << sum << endl;
    }
    return 0;
}
