vector<int> sdv1(vector<int> mass)
{
	int len = mass.size();
	int rec = mass[len-1];
	for (int i = len-1; i > 0; i--)
		mass[i] = mass[i-1];
	mass[0] = rec;
	return mass;
}

int sdvig (vector<int> mass, int sdv)
{
	for (int i = 0; i < sdv; i++)
	{
		swap(mass[mass.size()-i-1], mass[i]);
	}
	return -1;
}

