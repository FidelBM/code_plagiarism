#include "stdio.h"
#include "string.h"

#define MAX_A 10000000

char u[MAX_A] = {0};

int main()
{
	int N, a, b;
	scanf("%d", &N);
	for(int T = 1; T <= N; T ++)
	{
		memset(u, 0, sizeof(u));
		scanf("%d%d", &a, &b);
		int k = 1, x = a, r = -1, ans = 0;
		while(x)
		{
			k *= 10;
			x /= 10;
			r ++;
		}
		k /= 10;
		for(int i = a; i <= b; i ++)
			if(!u[i])
			{
				u[i] = 1;
				int x = i, s = 1;
				for(int j = 0; j < r; j ++)
				{
					x = x / 10 + x % 10 * k;
					if(!u[x] && x >= a && x <= b)
						s ++;
					u[x] = 1;
				}
				ans += s * (s - 1) / 2;
			}
		printf("Case #%d: %d\n", T, ans);
	}
	return 0;
}
