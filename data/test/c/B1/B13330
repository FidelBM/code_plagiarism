#include <iostream>
#include <algorithm>
#include<functional>
#include <string>
#include <stdio.h>
using namespace std;
char s1[10],s2[10];
int f(int len)
{
	for(int k=0;k<len;++k)
	{
		int ok=1;
		for(int i=0;i<len;++i)
			if(s1[i]!=s2[(i+k)%len])
			{
				ok=0;
				break;
			}
		if(ok)
			return 1;
	}
	return 0;
}
int main()
{
	freopen("D:\\Visual Studio 2008\\google code jam\\C-small-attempt0.in", "r", stdin ) ;

	freopen("D:\\Visual Studio 2008\\google code jam\\C-small-attempt0.out", "w", stdout ) ;


	int t,a,b;
	scanf("%d ",&t);
	for(int k=1;k<=t;++k)
	{
		int ans=0;
		cin>>a>>b;
		for(int i=a;i<=b;++i)
		{
			sprintf(s1,"%d",i);
			int len=strlen(s1);
			for(int j=i+1;j<=b;++j)
			{
				sprintf(s2,"%d",j);
				if(strlen(s2)>len)
					break;
				if(f(len))
					ans++;
			}
		}
		printf("Case #%d: %d\n",k,ans);
	}
	return 0;
}