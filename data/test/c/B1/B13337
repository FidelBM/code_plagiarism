#include <cstdio>
#include <set>
#include <algorithm>
using namespace std;

int topbit(int x){
    return x>=10?topbit(x/10)*10:1;
}

int main(){
    int cs,lo,hi;
    scanf("%d",&cs);
    for(int no=1;no<=cs;no++){
        scanf("%d%d",&lo,&hi);
        int ans=0;
        for(int i=lo;i<=hi;i++){
            int x=i,r=topbit(x);
            set<int> u;
            while(!u.count(x)){
                u.insert(x);
                x=x%10*r+x/10;
            }
            for(auto c:u) if(c>i && c<=hi) ans++;
        }
        printf("Case #%d: %d\n",no,ans);
    }
}
