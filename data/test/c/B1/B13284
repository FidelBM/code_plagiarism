#include <iostream>
#include <vector>
#include <sstream>
#include <set>
#include <stdexcept>
#include <fstream>


int Solve(int a, int b)
{
	std::set<std::pair<int, int> > recycled;

	for( size_t i = a; i <=b; ++i)
	{
		if( i % 100000 == 0)
		std::cout << i << std::endl;

		std::ostringstream ostr;

		ostr << i;
		std::string number = ostr.str();

	//	std::cout << i << std::endl;
		for( size_t j = 1; j < number.size(); ++j)
		{
			std::string newNumber = number.substr(j, number.size() - j) + number.substr(0, j);

		//	std::cout << "\t" << newNumber << std::endl;
			if (newNumber[0] != '0' )
			{
				std::istringstream istr(newNumber);
				size_t newNumberValue;
				istr >> newNumberValue;

				if(newNumberValue >= a && newNumberValue <= b && newNumberValue != i)
				{
					recycled.insert(std::make_pair(std::min(i, newNumberValue), std::max(i, newNumberValue) ) );
				}
			}
		}

	}
	return recycled.size();
}

int main(int argc, char** argv)
{
	int nbTest = 0;
	std::ifstream ifs( "Debug/C-small-attempt0.in");
	std::ofstream file( "Debug/C-small-attempt0.out" );

	ifs >> nbTest;
	std::string line;
	std::getline(ifs, line);

	for( int test = 1; test <= nbTest; ++test )
	{
		int a, b;

		ifs >> a;
		ifs >> b;

		int maxScore = Solve(a, b);

		std::cout << maxScore << std::endl;
		file << "Case #" << test << ": "<<  maxScore << std::endl;
	}
	std::cout << "Finish" << std::endl;
	return 0;
}
