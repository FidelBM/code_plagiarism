using namespace std;
map<pair<int,int>,bool> m;
int main()
{
   // freopen("C-small-attempt0.in","r",stdin);
   // freopen("outC.txt","w",stdout);
    int t;cin>>t;
    for(int ca=1;ca<=t;ca++)
    {
        m.clear();
        int A,B;
        cin>>A>>B;
        int ret = 0;
        for(int i=A;i<=B;i++)
        {
            stringstream ss;
            ss<<i;
            string test;ss>>test;
           for(int j=test.length()-1;j>=1;j--)
            {
                string te1 = test.substr(j);
                string te2 = test.substr(0,j);
                string n = te1+te2;
                stringstream ss1(n);
                int check;ss1>>check;
                if(check<i && check>=A && check<=B)
                {
                    m[make_pair(check,i)]=true;
                }
            }
        }
        cout<<"Case #"<<ca<<": "<<m.size()<<endl;
    }
}
