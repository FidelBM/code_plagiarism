#include<iostream>
#include<vector>
#include<string>
#include<sstream>
#include<cstdio>
#include<map>
#include<set>
using namespace std;
int main()
{
	int t, t1=1;
	cin>>t;
	while(t1<=t)
	{
		int a,b,count=0;
		cin>>a>>b;
		map<pair<int,int>, int>m;
		for(int i=a;i<=b;i++)
		{
			stringstream s1;
			s1<<i;
			string s;
			s = s1.str();
			int sSZ = s.size();
			for(int j=0;j<s.size()-1;j++)
			{
				string newStr = s.substr(j+1,sSZ-j-1) + s.substr(0,j+1);
				if(newStr[0]=='0' || s.compare(newStr)==0)continue;
				stringstream s2;
				s2<<newStr;
				int t1;
				s2>>t1;
				if(t1>=a && t1<=b)
				{
					int t2 = i;
					if(t2>t1)
					{
						int z1 = t2;
						t2 = t1;
						t1 = z1;
					}
					pair<int,int>pp = make_pair(t2,t1);
					if(!m[pp])
					{
						//cout<<pp.first<<" "<<pp.second<<endl;
						m[pp] = 1;
					}
				}
			}
		}
		cout<<"Case #"<<t1++<<": "<<m.size()<<endl;
	}
	return 0;
}
