#include<cstdio>
#include<iostream>
#include<string>
#include<cstring>
#include<vector>
#include<map>
#include<algorithm>
using namespace std;
int cnt[2000001];
int tran(int n){
    int c=0,p=1,ret=n;
    for(int t=n;t;t/=10,p*=10) c++;
    for(int i=1;i<c;i++)
        ret=min(ret,n=n/10+n%10*p/10);
    return ret;
}
int main(){
    //freopen("out","w",stdout);
    int cas=0,T,a,b;
    cin>>T;
    while(T--){
        memset(cnt,0,sizeof(cnt));
        long long ans=0;
        cin>>a>>b;
        for(int i=a;i<=b;i++){
            int t=tran(i);
            ans+=cnt[t];
            cnt[t]++;
        }
        cout<<"Case #"<<++cas<<": "<<ans<<endl;
    }
    //fclose(stdout);
}
