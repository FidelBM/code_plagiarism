typedef vector<int> VI;

int len(int n) {
	int l = 0;
	while(n!=0) {
		l++;
		n /= 10;
	}
	return l;
}

bool possible(int n, int m) {
	if(len(n)!=len(m))
		return false;
	char x[500], y[500];
	sprintf(x, "%d", n);
	sprintf(y, "%d", m);
	
	string s = x;
	string g = y;
	s += s;
	if(s.find(g)!=string::npos)
		return true;
	return false;
}

int main() {
	int t;
	scanf("%d", &t);
	int n, m;
	for(int k=1;k<=t;k++) {
		int cnt = 0;
		scanf("%d %d", &n, &m);
		for(int i=n;i<=m;i++) {

			for(int j=i+1;j<=m;j++) {
				cnt += possible(i, j);
			}
		}
			
		

		printf("Case #%d: %d\n", k, cnt);
	}
}
