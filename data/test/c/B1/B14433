template<class T>
T from_str(string s) {
	istringstream ss(s);
	T out;
	ss >> out;
	return out;
}

void solve_c(int cases)
{
	int A, B;
	for (int i = 0; i < cases; i++) {
		int result = 0;
		A = ni();
		B = ni();

		for (int j = A; j <= B; j++) {
			string num = to_str(j);
			int d = num.length();
			map<int, int> s;

			for (int k = 0; k < d; k++) {
				rotate(num.begin(), num.begin()+1, num.end());
				if (num[0] != '0') {
					int n = from_str<int>(num);
					if (n > j && n <= B && s[n] == 0) {
						result++;
						s[n] = 1;
					}
				}
			}
		}
		printf("Case #%d: %d\n", i+1, result);
	}

}

