int len;
int Min_num(char *s){
    int i=0, j=1, k=0, t;
    while( i<len && j<len && k<len ){
        t= s[ (i+k)%len ] - s[ (j+k)%len ];
        if(0==t) { ++k; continue; }
        if(t>0) i+= k+1;
        else j+= k+1;
        if(i==j) ++j;
        k= 0;
    }
    return i<j ? i : j;
}
bool ok(int x,int y){
    char cx[10], cy[10];
    int i= 0;
    while(x) cx[i++]= x%10 + '0', x/= 10;
    cx[i]= '\0';
    reverse( cx, cx+len );
    i= 0;
    while(y) cy[i++]= y%10 + '0', y/= 10;
    cy[i]= '\0';
    reverse( cy, cy+len );

    int sx, sy;
    sx= Min_num( cx );
    sy= Min_num( cy );
    char x1[10], x2[10];
    copy(cx+sx,cx+len,x1);
    copy(cx,cx+sx,x1+len-sx);
    x1[len]= '\0';
    copy(cy+sy,cy+len,x2);
    copy(cy,cy+sy,x2+len-sy);
    x2[len]= '\0';
    return (strcmp( x1, x2 )==0) ;
}

