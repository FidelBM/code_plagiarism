bool jud(int a,int b)
{
    int cnta(0),cntb(0),aa=a,bb=b;
    char sa[10],sb[10];
    while(a>0)
    {
        sa[cnta++]=a%10;
        a/=10;
    }
    while(b>0)
    {
        sb[cntb++]=b%10;
        b/=10;
    }
    if (cnta!=cntb) return false;
    int i=1;
    bool pp=false;
    while(i<max(cnta,cntb))
    {
        bool p=true;
        for (int j=0;j<cnta;j++)
            if (sa[(j+i)%cnta]!=sb[j]) {p=false; break;}

        if (p) {pp=true; break;}
        i++;
    }
    if (pp) return true;
    else
    return false;
}

int main()
{
    freopen("C-small-attempt0.in","r",stdin);
    freopen("C.out","w",stdout);
    int T;
    cin>>T;
    for (int cas=1;cas<=T;cas++)
    {
        int A,B,ans(0);
        cin>>A>>B;
        for (int i=A;i<=B;i++)
            for (int j=i+1;j<=B;j++)
            {
                if (jud(i,j))
                {
                    ans++;
                    //cout<<i<<" "<<j<<endl;
                }
            }
        cout<<"Case #"<<cas<<": "<<ans<<endl;
    }
    fclose(stdin);
    fclose(stdout);
}

