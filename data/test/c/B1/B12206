#include <cstdio>
#include <set>

using namespace std;

int main()
{
	freopen("in.txt","r",stdin);
	freopen("out.txt","w",stdout);
	int st[10];
	st[0]=1;
	for (int i=1; i<9; i++)
		st[i]=st[i-1]*10;
	int T;
	scanf("%d",&T);
	for (int t=0; t<T; t++) {
		printf("Case #%d: ",t+1);
		int a,b;
		set<pair<int,int>> h;
		h.clear();
		int ndig=1;
		scanf("%d%d",&a,&b);
		int res=0;
		while (a>=st[ndig]) ndig++;
		for (int A=a; A<=b; A++) {
			int dig[10];
			int tmp=A;
			for (int i=ndig; i>0; i--) {
				dig[i]=tmp % 10;
				tmp/=10;
			}
			for (int i=1; i<=ndig; i++) {
				tmp=0;
				int k=ndig-1;
				for (int j=i; j<=ndig; j++) {
					tmp+=st[k]*dig[j];
					k--;
				}
				for (int j=1; j<i; j++) {
					tmp+=st[k]*dig[j];
					k--;
				}

				if (tmp>A && tmp<=b && h.count(make_pair(A,tmp))==0) {
					res++;
					h.insert(make_pair(A,tmp));
				}
			}
		}
		printf("%d\n",res);
	}
	return 0;
}
