#include <sstream>
#include <fstream>
#include <algorithm>
#include <string>
#include <vector>
#include <iostream>
#include <string>
#include <map>
using namespace std;
void main()
{
	int A,B,T,n,m,count,s;
	stringstream strm,t;
	ifstream cin("input.in");
	ofstream cout("output.out");
	string str;
	cin>>T;
	cin.get();
	for(int j=1;j<=T;j++)
	{
		cin>>A>>B;
		cin.get();
		strm.str("");
		strm.clear();
		strm<<A;
		t.str("");
		strm.clear();
		s=strm.str().size();
		t<<s<<".in";
		ifstream b(t.str().c_str());
		count=0;
		while(b>>str)
		{
			strm.str("");
			strm.clear();
			strm<<str;
			strm>>n;
			map<int,int> dp;
			for(int i=0;i<s;i++)
			{
				str=str[str.length()-1]+str;
				str.erase(str.size()-1);
				strm.str("");
				strm.clear();
				strm<<str;
				strm>>m;
				strm<<n<<m;
				if(A<=n && m<=B && n<m && !dp[m])
				{
					count++;
					dp[m]=1;
				}
			} 
			
		}
		cout<<"Case #"<<j<<": "<<count<<endl;
	}
}