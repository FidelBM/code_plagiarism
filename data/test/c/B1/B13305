#include <cstdio>
#include <cstring>

#include <set>
#include <string>
#include <algorithm>

using namespace std;

int T, A, B, C;
string s, z;

char buff[ 105 ];

int main( void )
{
  scanf( "%d", &T );

  for( int tc = 1; tc <= T; ++tc ) {
    scanf( "%d%d", &A, &B );

    int Sol = 0;

    for( int i = A; i <= B; ++i ) {
      sprintf( buff, "%d", i );
      s = string( buff );

      set< int > r;

      for( int j = 1; j < s.size(); ++j ) {
	z = s.substr( j, s.size() - j ) + s.substr( 0, j );

	if( z[0] != '0' ) {
	  sscanf( z.c_str(), "%d", &C );
	  if( C >= A && C <= B && C != i ) r.insert( C );
	}
      }

      Sol += (int) r.size();
    }

    printf( "Case #%d: %d\n", tc, Sol / 2 );
  }

  return 0;
}
