void CmdLine::Init(int argc, const char* argv[])
{
	// skip the first argument (the filename)
	for (int i = 1; i < argc; ++i) {
		this->push_back(argv[i]);
	}
}

void CmdLine::Init(const string& line)
{
	size_t len = line.length();

	size_t first = 0;
	size_t last  = 0;
	bool inArg = false;

	while (last < len)
	{
		if (isspace(line[last]) && inArg == false)
		{
			// save current arg and begin a new one
			AddItem(line, first, last);
			first = last + 1;
		}
		else if (line[last] == '\"')
		{
			// save current arg and begin a new one
			AddItem(line, first, last);
			first = last + 1;
			inArg = !inArg;
		}
		++last;
	}
	// save last arg
	AddItem(line, first, last);
}

bool ReadLine(FILE *file, string& line)
{
	static vector<char> read(4096);

	bool retval = false;
	size_t pos = 0;

	int c = fgetc(file);
	while (c != EOF)
	{
		if (c == '\n')
		{
			read[pos] = '\0';
			//retval = true;
			line = &(read[0]);
			return true;
		}
		else
		{
			read[pos] = (char)c;
			++pos;
			if (pos >= read.size())
			{
				read.resize(read.size() * 2);
			}
		}
		c = fgetc(file);
	};

	if (ferror(file)) {
		throw exception("Couldn't read file!");
	} 
	if (feof(file)) {
		read[pos] = '\0';
		line = &(read[0]);
	}
	return false;
}


vector<string> SplitString(const string& text, unsigned int expectedNofItems)
{
	unsigned int start;
	unsigned int pos;

	bool store = false;

	vector<string> list;
	list.reserve(expectedNofItems);

	for (pos = 0; pos < text.length(); ++pos)
	{
		if (isspace(text.c_str()[pos]))
		{
			if (store)
			{
				list.push_back(text.substr(start, pos - start));
				store = false;
			}
		}
		else if (!store)
		{
			start = pos;
			store = true;
		}
	}

	if (store)
	{
		list.push_back(text.substr(start, pos - start));
	}

	return list;
}

vector<unsigned int> SplitUInt(const string& text, unsigned int expectedNofItems)
{
	vector<string> items = SplitString(text, expectedNofItems);

	vector<unsigned int> retval;
	retval.reserve(items.size());

	for (vector<string>::const_iterator it = items.begin(); it != items.end(); ++it)
	{
		unsigned int value;
		if (sscanf(it->c_str(), "%u", &value) != 1)
		{
			throw std::runtime_error("split: sscanf failed to parse value!");
		}
		retval.push_back(value);
	}
	return retval;
}

string MergeString(const vector<string>& items, const string& separator)
{
	string retval = "";
	retval.reserve((separator.length() + 256) * items.size());

	vector<string>::const_iterator it = items.begin();
	if (it != items.end())
	{
		retval += (*it);
		++it;
		while (it != items.end())
		{
			retval += separator;
			retval += (*it);
			++it;
		}
	}
	return retval;
}

string MergeUInt(const vector<unsigned int>& items, const string& separator)
{
	char number[16];
	string retval = "";
	retval.reserve((separator.length() + 16) * items.size());

	vector<unsigned int>::const_iterator it = items.begin();
	if (it != items.end())
	{
		sprintf(&(number[0]), "%u", (*it));
		retval += number;
		++it;
		while (it != items.end())
		{
			sprintf(&(number[0]), "%u", (*it));
			retval += separator;
			retval += number;
			++it;
		}
	}
	return retval;
}

