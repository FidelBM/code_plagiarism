#include<iostream>
using namespace std;

int surp(int x){
	int aa = x/3;
	aa++;
	if(x%3 == 2)
		aa++;
	return aa;

}
int unsurp(int x){
	int aa = x/3;
	if(x%3 != 0)
		aa++;
	return aa;
}
int main(){
	int T;
	int arr[200];
	cin>>T;
	int cas = 0;
	bool mark[200];
	while(T--){
		cas++;
		int n,s,p;
		cin>>n>>s>>p;
		for(int i = 0 ; i < n ; i++)
			cin>>arr[i];
		int cnt = 0 ;
		for(int i = 0 ; i < n && cnt < s; i++){
			if(arr[i] <= 28 && arr[i]>=2 && surp(arr[i])>=p && unsurp(arr[i])<p){
				mark[i]=1;
				cnt++;
			}
		}
		for(int i = 0 ; i < n && cnt < s; i++){
			if(mark[i] == 0 && arr[i]>=2 && arr[i]<=28 && surp(arr[i])>=p && unsurp(arr[i])<p){
				mark[i]=1;
				cnt++;
			}
		}
		int ans = 0;
		for(int i = 0 ; i < n ; i++){
			if(mark[i]){
				if(surp(arr[i])>=p)
					ans++;
			}else{
				if(unsurp(arr[i])>=p)
					ans++;
			}
		}
		cout<<"Case #"<<cas<<": "<<ans<<endl;
		for(int i = 0 ; i < n ; i++)
			mark[i]=0;
	}
}
