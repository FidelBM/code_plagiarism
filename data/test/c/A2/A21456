#include "Utils.h"

#include <cstdio>
#include <exception>
#include <vector>
#include <fstream>
#include <string>
using namespace std;

typedef struct {
	unsigned int normal;
	unsigned int surprising;
} Triplet;

void TripleTest(Triplet& triplet, unsigned int i, unsigned int j, unsigned int k, unsigned int sum, unsigned int threshold, bool surprising)
{
	if ((i + j + k) == sum)
	{
		if (k >= threshold)
		{
			if (surprising)
				triplet.surprising++;
			else
				triplet.normal++;
		}
	}
	else
	{
		throw exception("Something wrong with code!");
	}
}

Triplet CreateTriples(unsigned int sum, unsigned int threshold)
{
	Triplet triplet = { 0, 0 };
	unsigned int i;

	/* Not surprising */
	if ((sum % 3) == 0) {
		i = sum / 3;
		TripleTest(triplet, i, i, i, sum, threshold, false);
	}

	if (sum >= 1) {
		if (((sum - 1) % 3) == 0) {
			i = (sum - 1) / 3;
			TripleTest(triplet, i, i, i + 1, sum, threshold, false);
		}
	}

	if (sum >= 2) {
		if (((sum - 2) % 3) == 0) {
			i = (sum - 2) / 3;
			TripleTest(triplet, i, i + 1, i + 1, sum, threshold, false);
			TripleTest(triplet, i, i, i + 2, sum, threshold, true);
		}
	}

	/* Surprising */
	if (sum >= 3) {
		if (((sum - 3) % 3) == 0) {
			i = (sum - 2) / 3;
			TripleTest(triplet, i, i + 1, i + 2, sum, threshold, true);
		}
	}
	
	if (sum >= 4) {
		if (((sum - 4) % 3) == 0) {
			i = (sum - 4) / 3;
			TripleTest(triplet, i, i + 2, i + 2, sum, threshold, true);
		}
	}
	return triplet;
}

unsigned int Combine(vector<Triplet>& triplets, unsigned int nofSurprises)
{
	unsigned int answer = 0;
	unsigned int usedSurprises = 0;
	for (unsigned int i = 0; i < triplets.size(); ++i)
	{
		if (triplets[i].normal != 0)
		{
			++answer;
		}
		else
		{
			if ((usedSurprises < nofSurprises) && (triplets[i].surprising != 0))
			{
				answer++;
				usedSurprises++;
			}
		}
	}
	return answer;
}

int run(FILE *input, FILE *output)
{
	string line;

	unsigned int nofTests;
	bool read;

	read = ReadLine(input, line);
	if (sscanf(line.c_str(), "%u", &nofTests) != 1)
		throw exception("Unable to parse input!");

	if (read)
	{
		for (unsigned int i = 0; i < nofTests; ++i)
		{
			read = ReadLine(input, line);
			vector<unsigned int> items = SplitUInt(line, 256);

			vector<unsigned int> points;
			unsigned int nofGooglers = items[0];
			unsigned int nofSurprises = items[1];
			unsigned int bestScore = items[2];

			points.reserve(nofGooglers);
			for (unsigned int j = 0; j < nofGooglers; ++j)
			{
				points.push_back(items[3 + j]);
			}

			vector<Triplet> triplets;
			triplets.resize(nofGooglers);
			for (unsigned int j = 0; j < nofGooglers; ++j)
			{
				triplets[j] = CreateTriples(points[j], bestScore);
			}

			unsigned int answer = Combine(triplets, nofSurprises);

			fprintf(output, "Case #%u: %u", i + 1, answer);

			if (!read)
				break;
		}
	}
	return 0;
}

int main(int argc, const char *argv[])
{
	int retval = -1;
	try
	{
		CmdLine cmdLine(argc, argv);
		if (cmdLine.size() == 2)
		{
			string inpFile = cmdLine[0];
			string outFile = cmdLine[1];

			FILE *input = fopen(inpFile.c_str(), "rb");
			FILE *output = fopen(outFile.c_str(), "wb");
			
			if (input && output)
			{
				retval = run(input, output);
			}

			if (input) {
				fclose(input);
			}
			if (output) {
				fclose(output);
			}
		}
		if (retval == 0) {
			printf("Completed successfully.\n");
		} else {
			printf("Failed to complete successfully.\n");
		}
	}
	catch (const exception& e)
	{
		printf("Error: %s\n", e.what());
	}
	catch (...)
	{
		printf("Error: Unidentified exception!\n");
	}
	printf("\nPress a key to exit...");
	getc(stdin);
	printf("\n");
	return retval;
}