#include "algo.h"
#include <QString>
#include <QDebug>
#define max(a,b) ((a)<(b)?(b):(a))
#define min(a,b) ((a)>(b)?(b):(a))
#define sign(a) ((a)>0?1:((a)<0?-1:0))
#define theOther(a) ((a)==ORANGE?BLUE:ORANGE)

QMutex Algo::mutex;

void Algo::run()
{

    qDebug()<<"surprises "<<surprises;
    qDebug()<<"minScore "<<minScore;
    int surprisesRemain = surprises;
    int score = 0;
    if(minScore == 0)
    {

        this->result = QString::number(this->googlersScore.count());
        return;
    }

    int scoreOk = minScore + minScore-1 + minScore-1;
    int scoreNeedSurprise = minScore + minScore-2 + minScore-2;
    if(minScore == 1)
    {
        scoreNeedSurprise = scoreOk;
    }

    int current = 0;
    foreach(current, this->googlersScore)
    {
        //qDebug()<<current;
        if(current>=scoreOk)
        {
            score++;
        }else
        if(current>=scoreNeedSurprise && surprisesRemain)
        {
            surprisesRemain--;
            score++;
        }
    }


    result = QString::number(score);
}
