#include <iostream>
#include <cstdio>
#include <cstring>
#include <algorithm>
using namespace std;
struct Score
{
    int a,flag;
}t[110];
bool cmp(const Score &a, const Score &b)
{
    return a.a > b.a;
}
int main()
{
    freopen("B-large.in","r",stdin);
    freopen("B-large.out","w",stdout);
    int n,m,s,p;
    while(scanf("%d",&n)!=EOF)
    {
        int w = 1;
        while(n--)
        {
            int i,j;
            int temp;
            scanf("%d%d%d",&m,&s,&p);
            for(i=0;i<m;i++)
            {
                scanf("%d",&temp);
                if(temp%3 == 0)
                    t[i].a = temp/3 , t[i].flag = 1;
                else if(temp%3 == 1)
                    t[i].a = temp/3+1,t[i].flag = 0;
                else if(temp%3 == 2)
                    t[i].a = temp/3+1,t[i].flag = 1;
            }
            sort(t,t+m,cmp);
            for(i=0,j=0;i<m&&j<s;i++)
            {
                if(t[i].a==p-1&&t[i].flag&&t[i].a!=0&&t[i].a!=10)
                    t[i].a++,j++;
                if(t[i].a<p-1)
                    break;
            }
            int sum = 0;
            for(i=0;i<m;i++)
                if(t[i].a>=p)
                    sum++;
                else
                    break;
            printf("Case #%d: %d\n",w++,sum);
        }
    }
    return 0;
}
