#include <iostream>
#include <cstdio>
#include <string>
#include <cstring>
#include <cstdlib>
#include <algorithm>
using namespace std;

int t[109], n, k, p;
int a[109][12];

int s1(int i)
{
    if(t[i]<=1) return -1;
    else if(t[i]>=29) return -1;
    else if( (t[i]+1)/3+1 >= p ) return 1;
    return 0;
}

int s0(int i)
{
    if( (t[i]+2)/3 >= p ) return 1;
    else return 0;
}

int main()
{
    freopen("C:\\Users\\Administrator\\Downloads\\B-large.in","r",stdin);
    freopen("test.out","w",stdout);
    int cas, i, j;
    scanf("%d", &cas);
    for(i=1; i<=cas; i++)
    {
        scanf("%d%d%d", &n, &k, &p);
        memset(a, -1, sizeof(a));
        for(j=0; j<n; j++)
        {
            scanf("%d", &t[j]);
            int a0 = s0(j);
            int a1 = s1(j);
            //cout<<j<<' '<<a0<<' '<<a1<<endl;
            for(int jj=0; jj<=k; jj++)
            {
                if(j==0)
                {
                    a[j][0] = a0;
                    a[j][1] = a1;
                //cout<<j<<' '<<jj<<' '<<a[j][jj]<<endl;
                    continue;
                }
                else if(jj==0)
                {
                    a[j][0] = a[j-1][0]+a0;
                //cout<<j<<' '<<jj<<' '<<a[j][jj]<<endl;
                    continue;
                }
                if(a[j-1][jj-1]!=-1 && a1==1) a[j][jj] = a[j-1][jj-1]+1;
                if(a[j-1][jj]!=-1) a[j][jj] = max(a[j][jj], a[j-1][jj]+a0);
                //cout<<j<<' '<<jj<<' '<<a[j][jj]<<endl;
            }
        }
        printf("Case #%d: %d\n", i, a[n-1][k]);
    }
	return 0;
}
