bool Algo::isCorner(int row,int col)
{
    int cm=0;
    if(tab[row-1][col-1] == MIRROR) ++cm;
    if(tab[row][col-1] == MIRROR) ++cm;
    if(tab[row-1][col] == MIRROR) ++cm;
    if(tab[row][col] == MIRROR) ++cm;

    return cm==3;
}
double Algo::distance(Point p1,Point p2)
{
    return sqrt((p1.row-p2.row) * (p1.row-p2.row) + (p1.col-p2.col)*(p1.col-p2.col));
}
double Algo::distance(int p1,int p2)
{
    return sqrt((p1) * (p1) + (p2)*(p2));
}
bool Algo::rayTrace(int p1,int p2)
{
    int d = abs(hcf(p1,p2));
    int d1=p1/d;
    int d2=p2/d;
    //qDebug()<<"RAY "<<p1<<","<<p2<<"  hcf : "<<d;
    for(int i = 1; i<d; i++)
    {
        //qDebug()<<"t "<<(d1*i)<<","<<(d2*i);
        if(this->imSpace(d1*i,d2*i) == ME)
        {
            //qDebug()<<"Found Me between "<<p1<<","<<p2<<"  and  0,0";
            return false;
        }
    }
    return true;
}

