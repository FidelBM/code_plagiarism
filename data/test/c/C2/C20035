struct MyData
{
	Coord start;
	Coord now;
	Tuple direction;
	//Tuple already_went;
	Coord went;
	sc		D2; // D*D
	Tuple directionOrig;
	int nCrossed;

// 	inline bool Visible() const
// 	{
// 		return D2 >= already_went.a*already_went.a + already_went.b*already_went.b;
// 	}
	inline bool Visible() const
	{
		Tuple x2 = went.x;
		x2.Mul(went.x);
		Tuple y2 = went.y;
		y2.Mul(went.y);
		x2.Add(y2);
		x2.Norm();
		return D2 * x2.b >= x2.a;
	}
};

