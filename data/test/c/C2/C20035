bool GetNextXCoord(Coord& next)
{
	next = Coord();

	// Find next X coord cross:
	if(d.direction.a == 0)
	{
		// never
		return false;
	}

	if(d.direction.a > 0)
	{
		next.x.a = d.now.x.a/d.now.x.b + 1;
		next.x.b = 1;
	}
	else //if(d.direction.a < 0)
	{
		next.x.a = (d.now.x.a+d.now.x.b-1)/d.now.x.b - 1;
		next.x.b = 1;
	}
	ASSERT(next.x.a > 0 && next.x.a < g_W);

	Tuple DY = next.x;
	DY.Sub(d.now.x);
	DY.Div(d.direction);
	next.y = d.now.y;
	next.y.Add(DY);
	next.NormAll();
	return true;
}

//------------------------------------------------------

bool GetNextYCoord(Coord& next)
{
	next = Coord();

	// Find next Y coord cross:
	if(d.direction.b == 0)
	{
		// never
		return false;
	}

	if(d.direction.b > 0)
	{
		next.y.a = d.now.y.a/d.now.y.b + 1;
		next.y.b = 1;
	}
	else //if(d.direction.b < 0)
	{
		next.y.a = (d.now.y.a+d.now.y.b-1)/d.now.y.b - 1;
		next.y.b = 1;
	}
	ASSERT(next.y.a > 0 && next.y.a < g_H);

	Tuple DX = next.y;
	DX.Sub(d.now.y);
	DX.Mul(d.direction);
	next.x = d.now.x;
	next.x.Add(DX);
	next.NormAll();
	return true;
}

//------------------------------------------------------

bool GetNextMiddle(Coord& next)
{
	next = d.start; // Coord();

	// Find next middle (X):

// 	next.x.a = 2*d.now.x.a/d.now.x.b + 1;
// 	next.x.b = 2;
// 	next.y.a = 2*d.now.y.a/d.now.y.b + 1;
// 	next.y.b = 2;

// 	if(d.start.x.a != next.x.a || d.start.y.a != next.y.a)
// 	{
// 		// not a final square
// 		return false;
// 	}

	Coord diff = next;
	diff.x.Sub(d.now.x);
	diff.y.Sub(d.now.y);
	diff.NormAll();

// 	ASSERT(diff.x.b == 2);
// 	ASSERT(diff.y.b == 2);

	Tuple distance = diff.Diagon();
	if(distance > Tuple(1,2)) // half of diagonal in square
	{
		// too far
		return false;
	}

	Tuple dir2(diff.x.a*diff.y.b, diff.y.a*diff.x.b);
	if(dir2.a != 0 || dir2.b != 0)
		dir2.Norm();
	if(d.direction.a != dir2.a || d.direction.b != dir2.b)
	{
		// not the same vector
		return false;
	}

	return true;
}

