inline int IsEmpty(char ch)
{
	return (ch == '.' || ch == 'X') ? 1 : 0;
}

//------------------------------------------------------

void ProcessBorder()
{
	if(d.now.x.b == 1 && d.now.y.b == 1)
	{
		// We are at the coord cross
		const int x = (int)d.now.x.a;
		const int y = (int)d.now.y.a;
		ASSERT(x > 0 && x < g_W);
		ASSERT(y > 0 && y < g_H);
		char ch1 = g_v[y-1][x-1];
		char ch2 = g_v[y-1][x];
		char ch3 = g_v[y][x-1];
		char ch4 = g_v[y][x];

		int nEmpty = IsEmpty(ch1) + IsEmpty(ch2) + IsEmpty(ch3) + IsEmpty(ch4);
		ASSERT(nEmpty > 0);
		if(nEmpty == 4) // all are empty
			return;
		if(nEmpty == 1)
		{
			// internal corner
			d.direction.a = -d.direction.a;
			ASSERT(d.direction.a != 0);
			d.direction.b = -d.direction.b;
			ASSERT(d.direction.b != 0);
			return;
		}

		char chDirected = 0;
		if(d.direction.a < 0 && d.direction.b < 0) chDirected = ch1;
		if(d.direction.a >= 0 && d.direction.b < 0) chDirected = ch2;
		if(d.direction.a < 0 && d.direction.b >= 0) chDirected = ch3;
		if(d.direction.a >= 0 && d.direction.b >= 0) chDirected = ch4;

		if(nEmpty == 3)
		{
			if(!IsEmpty(chDirected))
			{
				// destroy!
				d.went.x = Tuple(999, 1);
				d.went.y = Tuple(999, 1);
			}
			return;
		}
		if(nEmpty == 2)
		{
			if(IsEmpty(chDirected))
			{
				//  X.
				//  .X
				return;
			}
			if((IsEmpty(ch1) && IsEmpty(ch2)) || (IsEmpty(ch3) && IsEmpty(ch4)))
			{
				// horizontal wall
				d.direction.b = -d.direction.b;
				ASSERT(d.direction.b != 0);
				return;
			}
			if((IsEmpty(ch1) && IsEmpty(ch3)) || (IsEmpty(ch2) && IsEmpty(ch4)))
			{
				// vertical wall
				d.direction.a = -d.direction.a;
				ASSERT(d.direction.a != 0);
				return;
			}
		}
		ASSERT(false);
	}
	else if(d.now.x.b == 1)
	{
		// X coord passing...
		const int x = (int)d.now.x.a;
		const int y = (int)(d.now.y.a / d.now.y.b);
		ASSERT(x > 0 && x < g_W);
		ASSERT(y > 0 && y < g_H);
		char ch1 = g_v[y][x-1];
		char ch2 = g_v[y][x];
		if(IsEmpty(ch1) && IsEmpty(ch2))
			return;
		ASSERT(IsEmpty(ch1) || IsEmpty(ch2));
		d.direction.a = -d.direction.a;
		ASSERT(d.direction.a != 0);
	}
	else if(d.now.y.b == 1)
	{
		// Y coord passing...
		const int x = (int)(d.now.x.a / d.now.x.b);
		const int y = (int)d.now.y.a;
		ASSERT(x > 0 && x < g_W);
		ASSERT(y > 0 && y < g_H);
		char ch1 = g_v[y-1][x];
		char ch2 = g_v[y][x];
		if(IsEmpty(ch1) && IsEmpty(ch2))
			return;
		ASSERT(IsEmpty(ch1) || IsEmpty(ch2));
		d.direction.b = -d.direction.b;
		ASSERT(d.direction.b != 0);
	}
	else
	{
		ASSERT(false);
	}
}

//------------------------------------------------------

bool check_direction()
{
start:
	if(!d.Visible())
		return false; // too long route...
	ASSERT(d.nCrossed < 10000);
#ifdef HIST
	if(d.nCrossed < MAX_HIST)
	{
		dHist[d.nCrossed] = d;
	}
#endif
	if(d.nCrossed == 1)
	{
		int dbg = 1;
	}

	Coord nextX;
	Coord nextY;
	Coord nextM;

	bool bFoundX = GetNextXCoord(nextX);
	bool bFoundY = GetNextYCoord(nextY);
	bool bFoundM = GetNextMiddle(nextM);

	Coord distX = nextX; if(bFoundX) distX.Sub(d.now);
	Coord distY = nextY; if(bFoundY) distY.Sub(d.now);
	Coord distM = nextM; if(bFoundM) distM.Sub(d.now);

	if(bFoundM)
	{
		d.went.AddAbs(distM);
		return d.Visible();
	}

	Tuple diagX = distX.Diagon();
	Tuple diagY = distY.Diagon();
	if((diagX < diagY && bFoundX && bFoundY) || (bFoundX && !bFoundY))
	{
		// X is nearer:
		d.went.AddAbs(distX);
		//Coord prevNow = d.now;
		d.now = nextX;
		ProcessBorder();
		d.nCrossed++;
		//return check_direction();
		goto start;
	}
	else
	{
		ASSERT(bFoundY);
		// Y is nearer:
		d.went.AddAbs(distY);
		d.now = nextY;
		ProcessBorder();
		d.nCrossed++;
		//return check_direction();
		goto start;
	}

	ASSERT(false);
	return false;
}

