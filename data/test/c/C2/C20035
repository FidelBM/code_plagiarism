tResult problem(const int Ti, const int H, const int W, const int M, const int D,
		const vector<tElement>& v)
{
	tResult res = 0;
	if(Ti == 0)
		printf("");

	g_v = v;
	g_H = H;
	g_W = W;

	{
		forn(y, H)
			forn(x, W)
		{
			if(v[y][x] == 'X')
			{
				d.start.x = Tuple(x * 2 + 1, 2);
				d.start.y = Tuple(y * 2 + 1, 2);
				break;
			}
		}
	}
	if(d.start.x.a == 0)
		return -1;
	d.D2 = D*D;
	d.start.NormAll();

	forab(dx, -D, D)
	{
		forab(dy, -D, D)
		{
			if(NOD(dx, dy) != 1)
				continue;
			d.now = d.start;
			d.direction = Tuple(dx, dy);
			d.directionOrig = d.direction;
			d.went = Coord();
			d.nCrossed = 0;

#ifdef HIST
			forn(k, MAX_HIST)
				dHist[k] = MyData();
#endif

			if(Ti == 4 && dx == 3 && dy == 1)
			{
				int dbg = 1;
			}

			bool bFound = check_direction();
			if(bFound)
			{
				res++;
			}
		}
	}

	return res;
}

