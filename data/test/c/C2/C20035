int main(int argc, char* argv[])
{
	const time_t t1 = clock();

	const int nTestType = argc > 1 ? atoi(argv[1]) : nDefaultTestType;
	const int nAttempt = argc > 2 ? atoi(argv[2]) : nDefaultAttempt;
	const bool bPracticeMode = bDefaultPracticeMode;

	const string sSmallPractice = bPracticeMode ? "-practice" : "-attempt" + ToStr(nAttempt);
	const string sBigPractice = bPracticeMode ? "-practice" : "";
	const string sFileIn0 = "test-practice.in";
	const string sFileOut0 = "test-practice.out";
	//const string sFileOut0Desired = "test-practice-desired.out";
	const string sFileIn1 = FILE_PREFIX "-small" + sSmallPractice + ".in";
	const string sFileOut1 = FILE_PREFIX "-small" + sSmallPractice + ".out";
	const string sFileIn2 = FILE_PREFIX "-large" + sBigPractice + ".in";
	const string sFileOut2 = FILE_PREFIX "-large" + sBigPractice + ".out";

	printf("Problem %s. %s (%s, attempt %d%s)\n", FILE_PREFIX, PROBLEM_NAME,
		nTestType == 0 ? "manual tests" : nTestType == 1 ? "Small Test" : "Big Test", nAttempt,
		bPracticeMode ? ", practice" : "");

	int res = 0;
	try
	{
		switch(nTestType)
		{
		case 0:
			res = process(sFileIn0, sFileOut0);
			break;
		case 1:
			res = process(sFileIn1, sFileOut1);
			break;
		case 2:
			res = process(sFileIn2, sFileOut2);
			break;
		default:
			printf("ERROR! Unknown test data index!\n");
			res = 1;
		}
	}
	catch (std::exception &e)
	{
		printf("ERROR! Unhandled std exception: %s: %s!\n", typeid(e).name(), e.what());
	}

	const time_t t2 = clock();
	printf("Work got %.2f seconds (%.3f sec/test).\n", ld(t2-t1)/1000.0, ld(t2-t1)/(1000.0*ld(res?res:1)));
	return 0;
}

