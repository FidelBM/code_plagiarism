typedef __int64 sc; // scalar

inline sc NOD(sc a, sc b)
{
	return abs264(nod(a, b));
}

//------------------------------------------------------

struct Tuple
{
	sc a;
	sc b;

	Tuple(sc a0 = 0, sc b0 = 0)
	{
		a = a0;
		b = b0;
	}

	inline void Norm()
	{
		const sc n = NOD(a, b);
		a /= n;
		b /= n;
	}

	inline void NormSign()
	{
		if(b < 0)
		{
			a = -a;
			b = -b;
		}
	}

	inline void Add(const Tuple& o)
	{
		const sc a1 = a * o.b + b * o.a;
		b *= o.b;
		a = a1;
	}

	inline void Sub(const Tuple& o)
	{
		const sc a1 = a * o.b - b * o.a;
		b *= o.b;
		a = a1;
	}

	inline void Mul(const Tuple& o)
	{
		a *= o.a;
		b *= o.b;
	}

	inline void Div(const Tuple& o)
	{
		a *= o.b;
		b *= o.a;
	}

	inline bool LessThanZero() const
	{
		return a != 0 && ((a < 0) ^ (b < 0));
	}
	inline bool GreaterThanZero() const
	{
		return a != 0 && !((a < 0) ^ (b < 0));
	}

	bool operator <(const Tuple& o) const
	{
		Tuple t = *this;
		t.Sub(o);
		return t.LessThanZero();
	}

	bool operator >(const Tuple& o) const
	{
		Tuple t = *this;
		t.Sub(o);
		return t.GreaterThanZero();
	}
};

struct Coord
{
	Tuple x;
	Tuple y;

	Coord()
	{
		x.b = 1;
		y.b = 1;
	}

	inline void NormAll()
	{
		x.Norm();
		y.Norm();
		x.NormSign();
		y.NormSign();
	}

	inline void Sub(const Coord& o)
	{
		x.Sub(o.x);
		y.Sub(o.y);
		x.Norm(); // is it necessary?
		y.Norm(); // is it necessary?
	}

	inline void Add(const Coord& o)
	{
		x.Add(o.x);
		y.Add(o.y);
		x.Norm(); // is it necessary?
		y.Norm(); // is it necessary?
	}

	inline void AddAbs(const Coord& o)
	{
		Coord t = o;
		t.x.a = abs264(t.x.a);
		t.x.b = abs264(t.x.b);
		t.y.a = abs264(t.y.a);
		t.y.b = abs264(t.y.b);
		x.Add(t.x);
		y.Add(t.y);
		x.Norm(); // is it necessary?
		y.Norm(); // is it necessary?
	}

	Tuple Diagon() const
	{
		Tuple dx = x;
		Tuple dy = y;
		dx.Mul(dx);
		dy.Mul(dy);
		dx.Add(dy);
		dx.Norm();
		return dx;
	}
};

