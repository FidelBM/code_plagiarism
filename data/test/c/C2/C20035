int process(const string& sFileIn, const string& sFileOut)
{
	FILE* fin = NULL; FOPEN(fin, sFileIn.c_str(), "rb");
	FILE* fout = NULL; FOPEN(fout, sFileOut.c_str(), "wb+");

	int T = 0;	// test count
	int i = 0;	// test index (1..T)
	int j = 0;

	int x1 = nod(5, 3);
	int x2 = nod(-5, 3);
	int x3 = nod(5, -3);
	int x4 = nod(-5, -3);
	sc y1 = NOD(0, 0);
	sc y2 = NOD(0, 5);
	sc y3 = NOD(5, 0);
	sc y4 = NOD(0, -5);
	sc y5 = NOD(-5, 0);

	fscanf(fin, "%d\n", &T);

	for(i = 1; i <= T; i++)
	{
		int H = 0;
		int W = 0;
		int M = 0;
		int D = 0;
		fscanf(fin, "%d %d %d\n", &H, &W, &D);
		printf("test #%d, H = %d, W = %d, D = %d\n", i, H, W, D);

		if(i == 0)
			printf("");

		vector<tElement> v;
		v.resize(H);
		for(j = 0; j < H; j++)
		{
			//fscanf(fin, "%d", &v[j]);
			char buf[1000] = "";
			fgets(buf, 999, fin);
			v[j] = buf;
		}

		if(i == 0)
			printf("");

		const tResult res = problem(i, H, W, M, D, v);
		printf("test #%d, res = %s\n\n", i, ToStr(res).c_str());
		fprintf(fout, "Case #%d: %s\n", i, ToStr(res).c_str());
	}

	fclose(fin);
	fclose(fout);
	printf("\nProcessed file: \"%s\" => \"%s\"\n", sFileIn.c_str(), sFileOut.c_str());
	return T;
}

