QMutex Algo::mutex;
int hcf(int a, int b)
{
    int t=0;
    if(a == 0)
    {
        return b;
    }
    if(b == 0)
    {
        return a;
    }
    if(abs(a)<abs(b))
    {
        t = b;
        b = a;
        a = t;
    }
    while(b != 0) {
        t = b;
        b = a%b;
        a = t;
    }

    return a;
}

