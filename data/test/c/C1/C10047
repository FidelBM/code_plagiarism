bool Algo::isCorner(int row,int col)
{
    int cm=0;
    if(tab[row-1][col-1] == MIRROR) ++cm;
    if(tab[row][col-1] == MIRROR) ++cm;
    if(tab[row-1][col] == MIRROR) ++cm;
    if(tab[row][col] == MIRROR) ++cm;

    return cm==3;
}
double Algo::distance(Point p1,Point p2)
{
    return sqrt((p1.row-p2.row) * (p1.row-p2.row) + (p1.col-p2.col)*(p1.col-p2.col));
}
double Algo::distance(int p1,int p2)
{
    return sqrt((p1) * (p1) + (p2)*(p2));
}
bool Algo::rayTrace(int p1,int p2)
{
    int d = abs(hcf(p1,p2));
    int d1=p1/d;
    int d2=p2/d;
    //qDebug()<<"RAY "<<p1<<","<<p2<<"  hcf : "<<d;
    for(int i = 1; i<d; i++)
    {
        //qDebug()<<"t "<<(d1*i)<<","<<(d2*i);
        if(this->imSpace(d1*i,d2*i) == ME)
        {
            //qDebug()<<"Found Me between "<<p1<<","<<p2<<"  and  0,0";
            return false;
        }
    }
    return true;
}

char Algo::imSpace(int row, int col)
{
    row += me.row;
    col += me.col;
    //qDebug()<<" row  "<<row;
    while(row >= this->height-1 || row<1)
    {
        if(row >= this->height-1)
        {
            row = this->height + this->height - row - 3;
        }
        if(row < 1)
        {
            row = -row + 1;
        }
    }
    //qDebug()<<" become "<<row;
    //qDebug()<<" col "<<col;
    while(col >= this->width -1 || col<1)
    {
        if(col >= this->width-1)
        {
            col = this->width + this->width - col - 3;
            //qDebug()<<" w "<<col;
        }
        if(col < 1)
        {
            col = -col + 1;
        }
    }
    //qDebug()<<" become "<<col;
    return this->tab[row][col];
}

bool Algo::reflette(Point mir,int f)
{
    if(mir.col == me.col)
    {
        if((abs(mir.row - me.row)-0.5)*2>f) return false;

        for(int i=min(mir.col,me.col);i<max(mir.col,me.col); ++i)
        {
            if(this->tab[i][(int)floor(mir.col)] == MIRROR)
            {
                return false;
            }
        }
        return true;
    }

    if(mir.row == me.row)
    {
        if((abs(mir.col - me.col)-0.5)*2>f) return false;

        for(int i=min(mir.row,me.row);i<max(mir.row,me.row); ++i)
        {
            if(this->tab[(int)floor(mir.row)][i] == MIRROR)
            {
                return false;
            }
        }
        return true;
    }
    return false;
}
