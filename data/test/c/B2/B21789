#include <stdio.h>
#include <math.h>

int getdig(int x)
{
	int ret = 0;
	while(x > 0)
	{
		x /= 10;
		ret++;
	}
	
	return ret;
}

int recycle(int x,int n)
{
	int tmp = x % 10;
	tmp *= pow(10, (n - 1));
	x /= 10;
	return (tmp+x);
}


int check(int a, int b, int x)
{
	int i;
	int ret = 0;
	int c = x;
	int n = getdig(c);


	for( i = 1; i < n; i++)
	{
		c = recycle(c, n);
		if(c >= a && c <= x)
		{
			return 0;
		}

		if(c > x && c <= b)
		{
			ret++;
		}
	}
	
	return ((1 + ret) * ret / 2);
}


int main()
{
	int n;
	int a,b;
	int i,j,k;
	int ans;
	
	scanf("%d", &n);
	for(k = 1; k <= n; k++)
	{
		scanf("%d %d", &a, &b);
		ans = 0;
		for(i = a; i <= b; i++)
		{
			ans += check(a, b, i);
		}

		printf("Case #%d: %d\n", k, ans);
	}

}
