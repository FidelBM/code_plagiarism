#include <iostream>
#include <cstdio>

using namespace std;

inline int f(int x)
{
	if ( x < 100 )
		return 10;
	else if ( x < 1000 )
		return 100;
	else if ( x < 10000 )
		return 1000;
	else if ( x < 100000 )
		return 10000;
	else if ( x < 1000000 )
		return 100000;
	else return 1000000;
}

int func(int x,int y)
{
	if ( y < 10 )
		return 0;
	else 
	{
		int count = 0;
		for ( int i = x ; i <= y ; ++i )
		{
			// 1 —Ò¶ÞÁ
			int number = i;
			int end = number % 10;
			number = end * f(number) + number/10;

			if ( number > i && number <= y ) ++count;

			// 2 —Ò¶Þ«
			number = i;
			end = number % 100;
			number = end * (f(number) / 10) + number / 100;
			if ( number > i && number <= y ) ++count;

			// 3 —Ò¶Þ«
			number = i;
			end = number % 1000;
			number = end * (f(number) / 100) + number / 1000;

			if ( number > i && number <= y ) ++count;

			// 4 —Ò¶Þ«
			number = i;
			end = number % 10000;
			number = end * ( f(number) / 1000) + number / 10000;

			if ( number > i && number <= y ) ++count;

			// 5 —Ò¶Þ
			number = i;
			end = number % 100000;
			number = end * ( f(number) / 10000) + number / 100000;

			if ( number > i && number <= y ) ++count;

			// 6 —Ò¶Þ
			number = i;
			end = number % 1000000;
			number = end * ( f(number) / 100000) + number / 1000000;

			if ( number > i && number <= y ) ++count;
		}
		return count;
	}
}

int main()
{
	freopen("C-large.in","r",stdin);
	freopen("C-large.out","w",stdout);

	int t; cin >> t;

	for ( int i = 0 ; i < t ; ++i )
	{
		int a,b; cin >> a >> b;
		cout << "Case #" << i + 1 << ": " << func(a,b) << endl;
	}

	return 0;
}
