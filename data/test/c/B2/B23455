#include <iostream>
#include <vector>
#include <cstring>

using namespace std;

int mark[2000000];

int A;
int B;

int cnb2(int n) {
  return (n * (n-1)) / 2;
}

int check(int i) {
  int cnt = 1;

  int kr = 1;
  while (kr <= i) {
    kr *= 10;
  }
  kr /= 10;

  for ( int keta=10 ; i >= keta ; keta*=10, kr/=10 ) {
    int m = i % keta;
    if (m < (keta/10)) {
      continue;
    }
    int rot = (i/keta) + (m * kr);
    if ( rot != i && A <= rot && rot <= B && !mark[rot-A]) {
      mark[rot-A] = 1;
      ++cnt;
    }
  }
  return cnb2(cnt);
}

int solve() {
  int res = 0;
  memset(mark, 0, 2000000);

  for (int i=A; i<B; ++i) {
    if (mark[i-A]) continue;
    res += check(i);
  }
  return res;
}

int main() {
  int T;
  cin >> T;
  for (int tc=1; tc<=T; ++tc) {
    cin >> A >> B;
    cout << "Case #" << tc << ": " << solve() << endl;
  }
}
