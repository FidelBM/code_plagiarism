static int intcmp(const void *p1, const void *p2)
{   
	/* The actual arguments to this function are "pointers to
	   pointers to char", but strcmp(3) arguments are "pointers
	   to char", hence the following cast plus dereference */

	return ((*(int const *) p1) - *((int const*)p2));
}

int test(int A,int B,int i,int dh,int dl,int mask,int m){
	int d;
	if(B<m*mask/10){
		return 0;
	}
	if(dh<mask){
		d=dl*mask+dh;
		if((d>=A)&&(d<=B)&&(d>i)){
			/*if(show==1){
				cout<<i<<" = "<<dh<<" "<<dl<<" = "<<d<<endl;
			}*/
			return 1;
		}
	}
	return 0;
}

//cheval type 1: abab:   a bab== aba b
//cheval type 2: abcabc:  a bcabc == abca bc; ab cabc== abcab c
//cheval type 3: ababab:  a babab == aba bab == ababa b
int cheval(int n){
	if(n%100==n/100){
		return 1;
	}
	if(n%1000==n/1000){
		return 2;
	}
	if(n%10000==n%100){
		if(n%100==(n/100)%100){
			return 3;
		}
	}
	return 0;
}


