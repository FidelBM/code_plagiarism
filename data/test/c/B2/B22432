#include<cstdio>
#include<algorithm>
#include<string>
#include<iostream>
#include<cstring>
using namespace std;
int a,b;
string tos(int a_){
    string s;
    while(a_){
        s+=(a_%10+'0');
        a_/=10;
    }

    int i,si=s.size();
    for(i=0;i<si/2;i++){
        char c=s[i];
        s[i]=s[si-1-i];
        s[si-i-1]=c;
    }
    return s;
}
bool iscy(string s,int a_){
    int m=0;
    int si=s.size();
    for(int i=0;i<si;i++){
        m=m*10+s[i]-'0';
    }
    if(m>a_ && m<=b) return true;
    return false;
}
int cy(int a_){
    string aa,bb;
    aa=tos(a_);
    int si=aa.size(),i,cnt=0;
    aa+=aa;
    for(i=0;i<si;i++){
        if(iscy(aa.substr(i,si),a_))
            cnt++;
    }
    return cnt;
}
int main(){
    int t,i,j,k;
    //freopen("C-large.in","r",stdin);
  // freopen("out.txt","w",stdout);
    scanf("%d",&t);
    for(k=1;k<=t;k++){
        scanf("%d %d",&a,&b);
        int cnt=0;
        for(i=a;i<=b;i++){
            cnt+=cy(i);
        }
        printf("Case #%d: %d\n",k,cnt);
    }
}
