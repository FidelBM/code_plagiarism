#define MAX 2000000

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <vector>

using namespace std;

void calc(vector<vector<int> > * x) {
	unsigned int i, j, k;
	bool add;
	char str[10], tmp[3][10];
	x->push_back(*new vector<int>());
	for (i = 1; i <= MAX; i++) {
		vector<int> *v = new vector<int>();
		sprintf(str, "%i", i);
		for (j = 0; j < strlen(str); j++) {
			memset(tmp[0], 0, sizeof(tmp[0]));
			strncpy(tmp[0], str, j + 1);
			memset(tmp[1], 0, sizeof(tmp[1]));
			strcpy(tmp[1], str + j + 1);
			memset(tmp[2], 0, sizeof(tmp[2]));
			strcat(tmp[2], tmp[1]);
			strcat(tmp[2], tmp[0]);
			if (atoi(tmp[2]) <= MAX) {
				add = true;
				for (k = 0; k < v->size(); k++) {
					if ((*v)[k] == atoi(tmp[2])) {
						add = false;
						break;
					}
				}
				if (add)
					v->push_back(atoi(tmp[2]));
			}
		}
		x->push_back(*v);
	}
}
;

int main() {
	int _, t, m, a, b, i;
	unsigned int j;
	vector<vector<int> > x;
	calc(&x);
	scanf("%i", &t);
	for (_ = 1; _ <= t; _++) {
		m = 0;
		scanf("%i %i", &a, &b);
		for (i = a; i < b; i++) {
			for (j = 0; j <= x[i].size(); j++) {
				if (x[i][j] > i && x[i][j] <= b) {
					m++;
				}
			}
		}
		printf("Case #%i: %i\n", _, m);
	}
	return 0;
}
