#include <stdio.h>

int main()
{
    int dec[8] = {10,100,1000,10000,100000,1000000,10000000};
    int i,j;
    int n;
    int a,b;
    int k,cnt;
    int mid;
    scanf("%d",&n);
    for(i=1;i<=n;i++)
    {
        cnt=0;
        scanf("%d%d",&a,&b);
        for(j=a;j<=b;j++)
        {
            for(k=0;j/dec[k]!=0;k++);
            k--;
            int t;
            for(t=0;t<=k;t++)
            {
                mid = j/dec[k-t] + j%dec[k-t]*dec[t];
                if( j<mid && mid<=b)
                {
                    //printf("%d\t%d",j,mid);
                    cnt++;
                }
            }
        }
        printf("Case #%d: %d\n",i,cnt);
    }
    return 1;
}
