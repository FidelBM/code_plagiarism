#include <cstdio>
#include <cstring>
#include <algorithm>

using namespace std;

int is_ok(int *a,int v,int &n){
    for(int i = 0;i < n; i++)
        if(a[i] == v) return 0;
    a[n] = v;
    n++;
    return 1;
}

int main(){

    //freopen("C-large.in","r",stdin);
    //freopen("C-large.out","w",stdout);

    int T,Cas = 1;
    scanf("%d",&T);
    while(T--){
        int a,b;
        scanf("%d%d",&a,&b);
        int sum = 0;
        for(int i = a; i < b; i++){
            char s1[10]="",s2[10]="",s3[20]="";
            sprintf(s1,"%d",i);
            strcpy(s2,s1);
            strcat(s2,s1);

            int len = strlen(s2);
            int res[10],tot = 0;
            for(int j = 1; j < strlen(s1); j++){
                int r = 0;
                for(int k = j; (k < j+strlen(s1))&&(k < len-1); k++)
                    s3[r++] = s2[k];
                s3[r] = 0;
                int v;
                sscanf(s3,"%d",&v);
                if(strlen(s1) > 1 && s3[0]!='0'&&i < v && v <= b && is_ok(res,v,tot)) {
                    sum++;
                }
            }
        }
        printf("Case #%d: %d\n",Cas++,sum);
    }
}
