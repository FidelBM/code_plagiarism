#define MAX_VAL 2000000

//n tem que ser maior q 10
int getminM(int n)
{
	int m = MAX_VAL + 1;
	int front, back, nm;
	int mul = 10, maxmul = 1;
	
	while (n/maxmul > 0) maxmul *= 10;
	
	while (n/mul > 0)
	{
		back = n % mul;
		front = n / mul;
		nm = back * maxmul / mul + front;
		
		if (nm < m && nm > n) {
			m = nm;
		}
		
		mul *= 10;
	}
	
	return m;
}

int getnumMs(int n, int b)
{
	int cnt = 0;
	int front, back, m;
	int mul = 10, maxmul = 1;
	set<int> allm;
	
	while (n/maxmul > 0) maxmul *= 10;
	
	while (n/mul > 0)
	{
		back = n % mul;
		front = n / mul;
		m = back * maxmul / mul + front;
		
		if (m <= b && m > n && allm.count(m) == 0) {
			cnt++;
			allm.insert(m);
		}
		
		mul *= 10;
	}
	
	return cnt;
}

int main()
{
	int t, a, b, cnt, nrecicled;
	
