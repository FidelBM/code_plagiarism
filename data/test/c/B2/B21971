// codejam.cpp : Defines the entry point for the console application.
//
#include <cstdio>
#include <iostream>
#include <cmath>
using namespace std;

int
main(int argc, char *argv[])
{
    unsigned T;
    cin >> T;
    for (unsigned iCase = 1; iCase <= T; ++iCase)
    {
        unsigned A, B;
        cin >> A >> B;
        unsigned cnt(0);

        unsigned nDigits(1);
        unsigned leading(1);
        unsigned X = A; while (X >= 10) {nDigits++; X -= X%10; X/= 10; leading*=10;}

        for (unsigned n = A; n <= B; ++n)
        {
            unsigned n_rotated = n;
            for (unsigned i = 1; i < nDigits; ++i)
            {
                unsigned rem = n_rotated % 10;
                n_rotated = (n_rotated - rem)/10;
                n_rotated += leading * rem;
                if (n_rotated > n && n_rotated <= B)
                {
                    cnt++;
                }
            }
        }
        std::cout << "Case #" << iCase << ": " << cnt << std::endl;
    }
}

