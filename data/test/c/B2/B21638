using namespace std;


//#define SMALL
#define LARGE
int main() 
{
int T,i,j,l,p,o,pairs,flag;
long int A,B,n,m,k,pair[8],carry;
#ifdef SMALL
	freopen("C.in","rt",stdin);
	freopen("C-small.out","wt",stdout);
#endif
#ifdef LARGE
	freopen("C-large.in","rt",stdin);
	freopen("C-large.out","wt",stdout);
#endif
    cin>>T;
    for(j =1;j<=T;j++)
    {
          
          cin>>A>>B;
          pairs=0;
          printf("Case #%d: ",j);
          
          for(p=0;(A/((long)pow(10.0,p)))!=0;p++);
          
          p=p-1;
          
         for(n =max(A,(long)10);n<=B;n++)
           {    for(o=0;o<9;o++)
                        pair[o]=0;      
                
                k=10;
                for(i=1;i<=p;i++)
                {
                      carry=(n%k)*(long(pow(10.0,(p+1))))/k;
                       m=n/k+carry;  
                                
                       if(m!=n&&m>=A&&m<=B)
                       {
                        flag=1;
                        pair[i]= m;
                        for(l=i-1;l>0;l--)
                              if(pair[l]==pair[i])
                                   {
                                            flag=0;
                                      //   cout<<n<<' '<<m<<' '<<pair[l]<<' '<<i<<' '<<l<<"    "; 
                                   }
                        if(flag==1)                   
                              pairs++;
                             // cout<<n<<' '<<m<<' '<<pair[i]<<' '<<i<<' '<<l<<"    "; 
                       }
                        k=k*10;
                }
           }  
           
           cout<<pairs/2<<"\n";
    }
    
    return 0;

}

