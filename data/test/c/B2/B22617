#include<iostream>
using namespace std;

int arr[8]={0, 0, 0, 0};
int lim1[8]={0, 0, 0, 0};
int lim2[8]={0, 0, 0, 0};
int tmpz[8]={0, 0, 0, 0};
int ans=0, l1, l2, num, s, ms=1;

int main()
{
    int i, j, t, n=0, tmps, cse=0;
    int a, b, tmp, k, flg=2;
    cin >> t;
    while(t--)
    {
      scanf("%d", &a);
      scanf("%d", &b);
    if(a >= 10 && b>=10)
    {
      tmp = b;
      n=0;
      while(tmp > 0)
        { 
         tmps = tmp%10;
         lim1[7-n] = tmps;
         n++;
         tmp = tmp/10;
        }
      l1 = n;
      
      tmp = a;
      n=0;
      while(tmp > 0)
        { 
         tmps = tmp%10;
         lim2[7-n] = tmps;
         n++;
         tmp = tmp/10;
        }
      l2 = n;
        
      n=0;
      for(i=a;i<b;i++)
       {
         tmp = i;
         n = 0;
        while(tmp > 0)
        { 
         tmps = tmp%10;
         arr[7-n] = tmps;
         n++;
         tmp = tmp/10;
        }
        
        for(j=0;j<8;j++)
         tmpz[j] = arr[j];
         ms = 1;
        num = n; 
            if(7-n == 3)
             {
                if(arr[7] == arr[5] && arr[6] == arr[4])
                 ms = 3;
             }
             else if(7-n == 1)
                {
                  if(arr[7] == arr[4] && arr[6] == arr[3] && arr[5] == arr[2])
                   ms = 5;
                }
         tmps = 0;
         while(tmps < n-ms)
         {
             
             tmp = arr[7];
            for(s=7;s>0;s--)
            { 
             if(8-n < s)
             arr[s] = arr[s-1];
            }        
             arr[8-n] = tmp;
             
             for(j=0;j<8;j++)
              {
                if(arr[j] < tmpz[j])
                   {
                    flg = 1;    
                    break;
                   }
                 else if(arr[j] > tmpz[j])
                   break;
              }
              
              if(j==8)
               flg = 1;
                          
             if(flg == 2)
             {
             for(j=4-num;j<8;j++)
              {
                 if(arr[j] < lim2[j])
                   {
                    flg = 1;    
                    break;
                   }
                 else if(arr[j] > lim2[j])
                   break;
              }
             }
             if(flg == 2)
             {
             for(j=4-l1;j<8;j++)
              {
                 if(arr[j] > lim1[j])
                  {
                    flg = 1;    
                    break;
                   }
                 else if(arr[j] < lim1[j])
                   break;
              }
             }
             if(flg == 2)
                ans++;
             tmps++;
             flg = 2;
         
         }
        arr[0] = 0;arr[1] = 0;arr[2] = 0;arr[3] = 0;arr[4] = 0;arr[5] = 0;arr[6] = 0;arr[7] = 0;
       }
      }
      else
         ans = 0;
       cse++;
       printf("Case #%d: %d\n", cse, ans);
       ans = 0;
        arr[0] = 0;arr[1] = 0;arr[2] = 0;arr[3] = 0;arr[4] = 0;arr[5] = 0;arr[6] = 0;arr[7] = 0;
        lim1[0] = 0;lim1[1] = 0;lim1[2] = 0;lim1[3] = 0;lim1[4] = 0;lim1[5] = 0;lim1[6] = 0;lim1[7] = 0;
        lim2[0] = 0;lim2[1] = 0;lim2[2] = 0;lim2[3] = 0;lim2[4] = 0;lim2[5] = 0;lim2[6] = 0;lim2[7] = 0;
    }
}
