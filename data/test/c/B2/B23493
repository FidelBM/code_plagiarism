#include <stdio.h>
#include <string.h>

int transform(int a, int b){
	return (a%10 * b) + a/10;
}

int answer(int a, int b, int exp, int d){
	long long int ans = 0;
	int i, j;
	for(i = a; i <= b; ++i){
		int k = i;
		for(j = 0; j < d; ++j){
			k = transform(k,exp);
			if(k > b || i >= k) continue;
			ans++;
		}
	}
	return ans;
}

int main(){
	freopen("b.in","r",stdin);
	freopen("b.out","w",stdout);
	int t, j, exp, a, b, it;
	scanf("%d",&t);
	for(j = 1; j <= t; ++j){
		scanf("%d %d",&a,&b);
		for(exp = 1, it = 0; a/exp >= 10; exp *= 10, it++);
		printf("Case #%d: ",j);		
		if(exp == 1)
			printf("0\n");
		else
			printf("%d\n",answer(a,b,exp,it));
	}
	return 0;
}
