string rotate(string temp)
{
 int i ;
 string s ;
 s.push_back(temp[temp.length()-1]) ;
 for(i = 0 ; i<temp.length()-1 ; i++)
  s.push_back(temp[i]) ;
   return s ;
}

string reverse_string(string s)
{
 string temp ;
 int i ;
 for(i = s.length()-1 ; i>=0 ;i--)
 temp.push_back(s[i]) ;
  return temp ;
 }

 
int convert_int(string s)
{
   char c ;
   int i ;
   int x = 0;
   int count = -1 ;
   for(i = s.length()-1 ; i>=0 ; i--)
   {
          x = x+pow(10,++count)*(s[i]-'0')  ;
    }
           return x ;
 }
     
   
string convert_string(int i)
{
    string s ;
    int temp = i ;
     char c ;
    while(temp != 0)
    {
       c = '0'+ temp%10 ;
       s.push_back(c) ;
       temp = temp /10 ;
     }
       s = reverse_string(s) ;
       return s ;
 }




