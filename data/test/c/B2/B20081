{
    ofstream fout("C-large.out");
    ifstream fin("C-large.in");
    int A[52],B[52];
    int T;
    int count;
    fin>>T;
    for (int i=1;i<=T;i++) fin>>A[i]>>B[i];

    for (int r=1;r<=T;r++)
    {
        count = 0;
        for (int i=A[r]; i<B[r]; i++)
            count += checkC(i,B[r]);

        fout<<"Case #"<<r<<": "<<count<<"\n";
    }

    return 0;
}
