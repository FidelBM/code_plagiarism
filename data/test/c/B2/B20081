#include <iostream>
#include <fstream>
using namespace std;

int mnum(int *a, int p, int q)
{
    if (a[p]==0) return 0;
    int num=a[p];
    for (int i=p+1; i<=q; i++)
    {
        num *= 10;
        num += a[i];
    }
    return num;
}

int checkC(int x,int lim)
{
	int *a = new int[16];
	int X=x;
	int r=0,count=0;

	while (x!=0)
	{
		a[r] = x%10;
		++r;
		x=x/10;
	}

	for (int i=0; i<r/2; i++)
	{
		swap(a[i],a[r-i-1]);
	}

	for (int i=0; i<r; i++)
	{
		a[r+i] = a[i];
	}

    for (int i=1; i<r; i++)
	{
        if (X<mnum(a,i,r+i-1) && mnum(a,i,r+i-1)<=lim) count++;
    }

	delete[] a;
	return count;
}

