#include <iostream>
#include <string>
#include <vector>
using namespace std;

int rec[2000001];

int main(){
	int  n , a , b , i , j;
	char s[10];
	while( scanf("%d",&n) != EOF ){
		rec[0] = 0;
		for( i = 1; i <= 2000000;i++ ) {
				sprintf(s,"%d",i);
				//cout<<i<<endl;
				string tmp = string(s);
				vector<int>ivec; ivec.clear();
				 {
					for( j = 1 ; j < tmp.length();j++ ) {
						string cur = tmp.substr( j, tmp.length()-j ) + tmp.substr( 0 , j);
						//cout<<cur<<endl;
						int itmp = atoi( cur.c_str() );
						if( itmp > i && itmp <= b){
							 ivec.push_back( itmp );
							// cout<<i<<" "<<itmp<<endl;
						}
					}
					//tmp = "0" + tmp;
				}
				rec[i] = rec[i-1];
				rec[i] += unique( ivec.begin() , ivec.end() ) - ivec.begin();
		}

		for( int tc = 1 ; tc <= n;tc++ ){
			scanf("%d%d",&a,&b);
			printf("Case #%d: %d\n",tc,rec[b]-rec[a-1]);
		}
	}
	return 0;
}