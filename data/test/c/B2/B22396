#include <iostream>
#include <string>
#include <set>

int strToInt(char *buff, int len, int shift)
{
	int result = 0;
	for(int i = 0; i < len; ++i)
	{
		int j = (i + shift) % len;
		result = result * 10 + (buff[j] - '0');
	}
	return result;
}

int main(int argc, char* argv[])
{
	int T;
	std::cin >> T;

	for(int test = 0; test < T; ++test)
	{
		int A, B;
		std::cin >> A;
		std::cin >> B;

		int pairs = 0;

		char buff[64] = { 0 };
		for(int n = A; n < B; ++n)
		{
			_itoa(n, buff, 10);
			int len = strlen(buff);

			std::set<int> mset;
			for(int sh = 1; sh < len; ++sh)
			{
				int m = strToInt(buff, len, sh);
				if(n < m && m <= B)
				{
					mset.insert(m);
				}
			}

			pairs += mset.size();
		}

		std::cout << "Case #" << test + 1 << ": " << pairs << std::endl;
	}

	return 0;
}

