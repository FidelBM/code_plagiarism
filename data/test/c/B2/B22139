#include <iostream>
#include <vector>
#include <fstream>
#include <string>
#include <math.h>
using namespace std;

long max1=0;

void recycle(long num, long B){
 long temp1,temp2,temp3,mul=1,digits=0,temp4;
 temp1=num;
 while(temp1){
  temp1=temp1/10;
  digits++;
 }
 temp1=num;
 for(long i=0;i<digits;i++){
  temp2=temp1/mul;
  temp3=temp1%mul;
  temp4=temp3*(long)pow(10,digits-i) + temp2;
  mul=mul*10;
  if((temp4<=B) && (num<temp4) && (temp4/(long)pow(10,digits-1)!=0)){
   max1++;
  }
 }
}

int main() {
 ifstream r1("C-large.in");
 long T;
 
 r1>>T;
 for(long i=0;i<T;i++){
  long A,B;
  r1>>A;
  r1>>B;
  max1=0;
  for(long j=A;j<B;j++){
   recycle(j,B);
  }
  cout<<"Case #"<<(i+1)<<": "<<max1<<endl;
 }
 
 return 0;
}
