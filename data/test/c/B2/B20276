int A, B;

string int_to_str(int n) {
    stringstream s;
    s << n;
    return s.str();
}

int str_to_int(string str) {
    atoi(str.c_str());    
}

int get_all_for(int n) {
    string str_n = int_to_str(n);
    int add = 0;
    for(int i = 0; i < str_n.size(); i++) {
        rotate(str_n.begin(), str_n.end() - 1, str_n.end());
        int m = str_to_int(str_n);
        if(n < m && m <= B) {
            add++;
        }
    }
    return add;
}

