#include <algorithm>
#include <iostream>
#include <vector>
#include <functional>
#include <string>
using namespace std;


int main (){
	int i,j,k,t=0,T, A, B, res,  length, temp1;
	char *temp;
	bool flag;
	temp=(char*)malloc(sizeof(int));
	freopen("data.in","r",stdin);
	freopen("data.out","w",stdout);
	cin >> T;
	while (t<T){
		cin >> A;
		cin >> B;
		res=0;
		itoa(A,temp,10);
		length=strlen(temp);
		j=A;
		if (length==1|| A==B) goto exit;

		while (j >= A && j <= B){
			vector<int> test;
			flag = 0;
			k=0;
			for (i=1;i<length;i++){
				itoa(j,temp,10);
				rotate(temp,temp+i,temp+length);
				temp1=atoi(temp);
				if (temp1>j && temp1 <=B){
					while (k<test.size()){
					 if (test[k]==temp1) flag = 1;
					 k++;
					}
					if (!flag) {res++; test.push_back(temp1);}
				}
			}
			j++;
		}
	exit:
	cout << "Case #" << ++t << ": " << res << endl;
	}

	return 0;
}
