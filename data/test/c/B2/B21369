const int INF = (1LL<<31)-1;

int A,B;
int P[10] = {1,10,100,1000,10000,100000,1000000,10000000};

int howMany( int a ){

    int n = 0;
    while( a / P[n] )
        ++n;

    int ret = 0,b = 0,bb,cur;
    for(int i = 0;i<n;++i){

        cur = (a/P[i])%10;
        if(!cur)continue;

        b += P[i]*cur;
        bb = a/P[i+1];
        bb += b*P[ n-i-1 ];

        if( bb > a && bb <= B )
            ++ret;

    }

    return ret;

}

