int aaaaa[8] = {0,0,0,0,0,0,0,0};

inline int rotate(int d, int a){
	return (a%10)*d+a/10;
}

inline int counter(int d, int a, int dd, int n, int m){
	int answer=1;
	aaaaa[0] = a;
	//cout << a;
	for(int i=1; i<d; i++){
		a = rotate(dd,a);
		aaaaa[i] = a;
		bool bad = false;
		for(int j=0; j<i; j++){
			if(a==aaaaa[j]){
				bad = true;
				break;
			}
		}
		if(a>=n && a<=m && !bad){
			answer++;
			//cout << " " << a;
		}
	}
	//cout <<"     " << p[answer] << endl;
	return p[answer];
}
inline int pow10(int d){
	int i=1; 
	for(int x=0; x<d; x++){
		i*=10;
	}
	return i;
}
