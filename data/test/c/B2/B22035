#include <iostream>
#include <vector>

using namespace std;

const int _size = 2000000;
int _pow[20];
vector<int> _rev[_size];

void gen(int n) {
  int p = n, cnt = 0;
  while (p > 9) {
    ++cnt;
    p /= 10;
  }
  for (int i = 1; i <= cnt; ++i) {
    int t = n / _pow[i] + (n % _pow[i]) * _pow[cnt + 1 - i];
    if (t > n) _rev[n].push_back(t);
  }
}

void solve() {
  int A, B, ans = 0;
  cin >> A >> B;
  for (int i = A; i <= B; ++i) {
    for (int j = 0; j < _rev[i].size(); ++j)
      if (_rev[i][j] <= B) ++ans;
  }
  cout << ans << endl;
}

void init() {
  _pow[0] = 1;
  for (int i = 1; i < 20; ++i)
    _pow[i] = _pow[i - 1] * 10;
  for (int i = 1; i <= _size; ++i) {
    gen(i);
  }
}

int main() {
  init();
  int ncs;
  cin >> ncs;
  for (int i = 1; i <= ncs; ++i) {
    cout << "Case #" << i << ": ";
    solve();
  }
  return 0;
}
