#include <cstring>
#include <cstdlib>
using namespace std;

#define MM 2000010

int a[MM], x, y;
int sum[MM];
char g[20];
int po[]={1,10,100,1000,10000,100000,1000000,10000000};

int rec(int i, int j){
	if(!i)return 0;
	return (sum[j]-sum[i])-rec(i/10,j/10);
}

int main (){
	memset(a,0,sizeof(a));
	
	for(int k=1;k<MM;++k){
		sprintf(g,"%d", k);
		int n=strlen(g);
		int z=k;
		int w;
		map<int,bool> m;
		for(int i=1;i<n;++i){
			w=z%10;
			z/=10;
			z+=w*po[n-1];
			if(k<z&&z<MM){
				if(!m[z]){
					a[z]++;
					m[z]=1;
				}
			}
		}
	}
	
	sum[0]=0;
	for(int i=1;i<MM;++i){
		sum[i]=a[i]+sum[i-1];
		// printf("%d | %3d (%d)\n", i, sum[i], a[i]);
	}
	
	
	int t;
	scanf("%d", &t);
	for(int cc=1;cc<=t;++cc){
		scanf("%d%d", &x, &y);
		printf("Case #%d: %d\n", cc, rec(x,y));
	}
	
	
	return 0;
}
