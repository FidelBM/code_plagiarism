#include <iostream>
#include <cstring>
#include <cstdio>
#include <cstring>
using namespace std;
int n,m,a,b,ans,t,cas;
int main()
{
    freopen("cycle.in","r",stdin);
    freopen("cycle.out","w",stdout);
    cin>>cas;
    while(cas--)
    {
    long long ans=0;
    cin>>a>>b;
    for(m=1;m<=b;m*=10);
    for(int i=a;i<=b;i++)
    {
    for(int k=1;k<=b;k*=10)
    {
        int j=((i/k)+(i%k)*(m/k));
        if(i!=j&&j>=a&&j<=b)ans++;
    }
    }
    printf("Case #%d: %I64d\n",++t,ans/(long long)2);
    }
}
