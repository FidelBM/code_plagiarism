int numPair (int a, int b)
{
    std::stringstream Num;
    std::string str;

    bool sim = false;

    string A;

    int num = 0;
    string c, d;
    int k;

    Num << a;
    A = Num.str();

    int n = 0;
    int l = A.length ();

    while (n<l)
    {
        d= A;
        c = A.substr (l-1-n, n+1);

        d.erase (l-1-n, n+1);
        if (c==d)
        {
            sim = true;
        }

        d = c + d;
        n++;
       if (d[0]!='0')
        {
            k = atoi(d.c_str());
            //cout << "   k= " << k << endl;

            if (a<k && k<=b && !sim)
            {
                num++;

            }
        }
    }
    return num;

}


