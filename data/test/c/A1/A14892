void read_file(char *szFile_in, char *szFile_out)
{
	FILE *fp_in;
	FILE *fp_out;

	if ((fp_in=fopen(szFile_in, "r"))==NULL)
	{
		printf("kann File %s nicht oeffnen\n", szFile_in);
		exit(-1);
	}
	if ((fp_out=fopen(szFile_out, "w"))==NULL)
	{
		printf("kann File %s nicht oeffnen (w)\n", szFile_out);
		exit(-1);
	}

	int nT, nN, nS, np;
	
	int i, j;

	int nMin_surp_for_p;
	int nMin_for_p;
	int nt;
	int nNum_t_for_p;
	
	// num. samples
	fscanf(fp_in, "%d", &nT);
	for (i=0; i<nT; i++)
	{

		fscanf(fp_in, "%d%d%d", &nN, &nS, &np);
#ifdef VERBOSE
		printf("\nN: %d, S: %d, p: %d\n", nN, nS, np);
#endif
		nMin_surp_for_p = 3*np-4;
		if (nMin_surp_for_p<0)
			nMin_surp_for_p=0;
		nMin_for_p = 3*np-2;
		if (nMin_for_p<0)
			nMin_for_p=0;
		nNum_t_for_p = 0;
		
		for (j=0; j<nN; j++)
		{
			fscanf(fp_in, "%d", &nt);			
#ifdef VERBOSE
			printf("  t[%d]: %d\n", j, nt);
#endif
			if (nt==0 && np>0)
				continue;
			if (nt>=nMin_for_p)
				nNum_t_for_p++;
			else if (nt>=nMin_surp_for_p && nS>0)
			{
				nS--;
				nNum_t_for_p++;
			}			
		}
				
#ifdef VERBOSE
		printf("case %d: %d\n", i+1, nNum_t_for_p);
#endif

		fprintf(fp_out, "Case #%d: %d\n", i+1, nNum_t_for_p);

		fflush(fp_out);
	}

	fclose(fp_in);
	fclose(fp_out);
}
