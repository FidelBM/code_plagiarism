#include "stdafx.h"

#include "CppUtils.h"

using namespace std;

struct ScoreTriplet
{
	int first;
	int second;
	int third;
};

typedef vector<ScoreTriplet> Possibilities;

bool IsSurprise(const ScoreTriplet& triplet)
{
	return abs(triplet.first - triplet.second) == 2 ||
		abs(triplet.first - triplet.third) == 2 ||
		abs(triplet.second - triplet.third) == 2;
}

bool IsValid(const ScoreTriplet& triplet)
{
	return abs(triplet.first - triplet.second) <= 2 &&
		abs(triplet.first - triplet.third) <= 2 &&
		abs(triplet.second - triplet.third) <= 2;
}

vector<ScoreTriplet> GetPossibleTriplets(int totalScore)
{
	vector<ScoreTriplet> triplets;

	for (int i = 0; i <= 10; ++i)
	{
		for (int j = 0; j <= 10; ++j)
		{
			for (int k = 0; k <= 10; ++k)
			{
				if (i + j + k == totalScore)
				{
					ScoreTriplet triplet;
					triplet.first = i;
					triplet.second = j;
					triplet.third = k;

					if (IsValid(triplet))
						triplets.push_back(triplet);
				}
			}
		}
	}

	return triplets;
}

int GetNumSurprises(const vector<ScoreTriplet>& triplets)
{
	int numSurprises = 0;

	for (vector<ScoreTriplet>::const_iterator it = triplets.begin(); it != triplets.end(); ++it)
	{
		if (IsSurprise(*it))
			numSurprises++;
	}

	return numSurprises;
}

int GetNumWithResultOrBetter(const vector<ScoreTriplet>& triplets, int bestResult)
{
	int num = 0;

	for (vector<ScoreTriplet>::const_iterator it = triplets.begin(); it != triplets.end(); ++it)
	{
		if (it->first >= bestResult || it->second >= bestResult || it->third >= bestResult)
			num++;
	}

	return num;
}

int GetMaxNumGooglersWithBestResult(int numSurprises, int bestResult, const vector<int> totalScores)
{
	vector<Possibilities> possibilities;

	for (unsigned int i = 0; i < totalScores.size(); ++i)
	{
		vector<ScoreTriplet> possibleTriplets = GetPossibleTriplets(totalScores[i]);

		possibilities.push_back(possibleTriplets);
	}

	int maxNum = 0;

	if (possibilities.size() == 1)
	{
		for (unsigned int i = 0; i < possibilities[0].size(); ++i)
		{
			ScoreTriplet tripleti = possibilities[0][i];

			vector<ScoreTriplet> theseTriplets;
			theseTriplets.push_back(tripleti);

			if (GetNumSurprises(theseTriplets) == numSurprises)
			{
				maxNum = max(maxNum, GetNumWithResultOrBetter(theseTriplets, bestResult));
			}
		}
	}
	else if (totalScores.size() == 2)
	{
		for (unsigned int i = 0; i < possibilities[0].size(); ++i)
		{
			for (unsigned int j = 0; j < possibilities[1].size(); ++j)
			{
				ScoreTriplet tripleti = possibilities[0][i];
				ScoreTriplet tripletj = possibilities[1][j];

				vector<ScoreTriplet> theseTriplets;
				theseTriplets.push_back(tripleti);
				theseTriplets.push_back(tripletj);

				if (GetNumSurprises(theseTriplets) == numSurprises)
				{
					maxNum = max(maxNum, GetNumWithResultOrBetter(theseTriplets, bestResult));
				}
			}		
		}
	}
	else if (totalScores.size() == 3)
	{
		for (unsigned int i = 0; i < possibilities[0].size(); ++i)
		{
			for (unsigned int j = 0; j < possibilities[1].size(); ++j)
			{
				for (unsigned int k = 0; k < possibilities[2].size(); ++k)
				{
					ScoreTriplet tripleti = possibilities[0][i];
					ScoreTriplet tripletj = possibilities[1][j];
					ScoreTriplet tripletk = possibilities[2][k];

					vector<ScoreTriplet> theseTriplets;
					theseTriplets.push_back(tripleti);
					theseTriplets.push_back(tripletj);
					theseTriplets.push_back(tripletk);

					if (GetNumSurprises(theseTriplets) == numSurprises)
					{
						maxNum = max(maxNum, GetNumWithResultOrBetter(theseTriplets, bestResult));
					}
				}
			}		
		}
	}

	return maxNum;
}

vector<string> Run(const vector<string>& inputLines)
{
	vector<string> outputLines;

	for (unsigned int i = 1; i < inputLines.size(); ++i)
	{
		string line = inputLines[i];

		if (line == "")
			continue;

		vector<string> inputs = CppUtils::Split(line, ' ');

		int numGooglers = atoi(inputs[0].c_str());
		int numSurprises = atoi(inputs[1].c_str());
		int bestResult = atoi(inputs[2].c_str());

		vector<int> totalScores;

		for (unsigned int j = 3; j < inputs.size(); ++j)
		{
			totalScores.push_back(atoi(inputs[j].c_str()));
		}

		int max = GetMaxNumGooglersWithBestResult(numSurprises, bestResult, totalScores);

		outputLines.push_back(CppUtils::Stringify(max));
	}

	return outputLines;
}

int _tmain(int argc, _TCHAR* argv[])
{
	string fileIn = argv[1];
	string fileOut = argv[2];
	
	vector<string> inputLines = CppUtils::GetLinesFromFile(fileIn);

	vector<string> outputLines = Run(inputLines);

	CppUtils::WriteLinesToFile(fileOut, outputLines, true);

	return 0;
}


