using namespace std;
#define pb         push_back
#define all(a)     (a).begin(),(a).end()
#define sz(a)      (int)((a).size())
#define rep(i,n)   for(int i=0; i<n; ++i)
#define REP(i,j,k) for(int i=j; i<k; ++i)
#define itr(T,v,i) for(T::iterator       i=v.begin(); i!=v.end(); i++)
#define ITR(T,v,i) for(T::const_iterator i=v.begin(); i!=v.end(); i++)
typedef long long ll;
int    INF = 100000000;
double EPS = 1e-8;

int result, n, s, p;
vector<int> t, v;

void dfs(int x) {
  if (x < 0) {
    int surprise = 0, good = 0;
    rep (i, n) {
      surprise += v[3*i+2]-v[3*i] == 2;
      good += v[3*i+2] >= p;
    }
    if (surprise == s) result = max(result, good);
    return;
  }
  rep (i, 11) REP (j, i, min(11, i+3)) REP (k, j, min(11, i+3)) {
    if (i+j+k == t[x]) {
      v[3*x] = i, v[3*x+1] = j, v[3*x+2] = k;
      dfs(x-1);
    }
  }
}

int main () {
  int TC; scanf("%d", &TC);
  rep (tc, TC) {
    scanf("%d %d %d", &n, &s, &p);
    t.clear(); t.resize(n);
    v.clear(); v.resize(3*n);
    rep (i, n) scanf("%d", &t[i]);
    result = 0;
    dfs(n-1);
    
    cout << "Case #" << tc+1 << ": " << result << endl;
  }
  return 0;
}
