#include "Solution.hpp"

#include <boost/cstdint.hpp>

#include <sstream>
#include <vector>

//-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~
namespace GCJFramework {
//-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~
bool
Solution::execute(std::istream& _inputStream, std::ostream& _outputStream) const
{
    boost::uint32_t testCases;

    _inputStream >> testCases;

    for (boost::uint32_t i = 0; i < testCases; ++i)
    {
        std::stringstream stream;
        int numGooglers;
        int numSuprisingResults;
        int bestResult;
        int foundPossibleResults = 0;
        int foundSuprisingResults = 0;
        _inputStream >> numGooglers >> numSuprisingResults >> bestResult;
        for (int i = 0; i < numGooglers; i++)
        {
            int total;
            _inputStream >> total;
            int residual = total - 3 * bestResult;
            if (residual >= -2)
            {
                foundPossibleResults++;
            }
            else
            if (foundSuprisingResults < numSuprisingResults &&
                total >= bestResult &&
                residual >= -4)
            {
                foundPossibleResults++;
                foundSuprisingResults++;
            }
        }
        stream << "Case #" << i+1 << ": " << foundPossibleResults << std::endl;
        _outputStream << stream.str();
    }

    return true;
}

//-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~-~
}   // namespace GCJFramework
