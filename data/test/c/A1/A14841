#include <iostream>
#include <fstream>
#include <cstring>
#include <cmath>
#include <climits>
#include <cstdio>
#include <algorithm>




using namespace std;
const int MAXN = 110;
int T;
int N;
int S, p;
int t[MAXN];
int cnt[8] = {0, 1, 1, 2, 1, 2, 2, 3};
int main()
{
    freopen("input.txt", "r", stdin);
    freopen("output.txt", "w", stdout);
    scanf("%d", &T);
    for(int i = 0; i < T; i++)
    {
        int nMax = 0;
        scanf("%d %d %d", &N, &S, &p);
        for(int j = 0; j < N; j++)
        {
            scanf("%d", &t[j]);
        }

        for(int mask = 0; mask < (1 << N); mask++)
        {
            int tMax = 0;
            if(cnt[mask] != S) continue;
            for(int j = 0; j < N; j++)
            {
                if((1 << j) & mask)
                {
                    bool ok = false;
                    if((t[j] + 2) % 3 == 0 && (t[j] + 2) / 3 - 2 >= 0)
                    {
                        int tmp = (t[j] + 2) / 3;
                        if(tmp >= p && tmp <= 10) ok = true;
                    }
                    if(t[j] % 3 == 0 && (t[j] / 3 - 1 >= 0))
                    {
                        int tmp = (t[j]) / 3 + 1;
                        if(tmp >= p && tmp <= 10) ok = true;
                    }
                    if((t[j] + 4) % 3 == 0 && (t[j] + 4) / 3 - 2 >= 0)
                    {
                        int tmp = (t[j] + 4) / 3;
                        if(tmp >= p && tmp <= 10) ok = true;
                    }
                    if(ok) tMax++;
                }
                else
                {
                    int tmp = (t[j] / 3) + (t[j] % 3 > 0);
                    if(tmp >= p) tMax++;
                }
            }
            if(tMax > nMax) nMax = tMax;
        }

        printf("Case #%d: %d\n", i + 1, nMax);


    }











    return 0;
}
