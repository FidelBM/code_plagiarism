#include <iostream>
#include <string.h>
using namespace std;

int main()
{
	int nt, n, s, p, cnt, score, mean;
	
	cin >> nt;
	
	for (int teste = 1; teste <= nt; teste++)
	{
		cin >> n >> s >> p;
		cnt = 0;
		for (int i = 0; i < n; i++)
		{
			cin >> score;
			mean = score / 3;
			if (score == 0 && p == 0) cnt++;
			if (score > 0) {
				if (mean >= p) cnt++;
				else if (mean == p - 1)
				{
					if (score % 3 != 0) cnt++;
					else if (s > 0) {
						s--;
						cnt++;
					}
				}
				else if (mean == p - 2)
				{
					if (score % 3 == 2 && s > 0)
					{
						s--;
						cnt++;
					}
				}
			}
		}
		cout << "Case #" << teste << ": " << cnt << endl;
	}
	
	return 0;
}
