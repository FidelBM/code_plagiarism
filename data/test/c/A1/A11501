#ifndef UTILS_H_
#define UTILS_H_

#include <string>
#include <vector>

class CmdLine 
	:	public std::vector<std::string>
{
public:
	CmdLine() {}

	CmdLine(int argc, const char* argv[])
		{ Init(argc, argv); }

	CmdLine(const std::string& line)
		{ Init(line); }

	void Init(int argc, const char* argv[]);

	void Init(const std::string& line);

protected:
	void AddItem(const std::string& line, size_t first, size_t last)
	{
		if (first < last) {
			this->push_back(line.substr(first, last - first));
		}
	}
};

bool ReadLine(FILE *file, std::string& line);

std::vector<std::string> SplitString(const std::string& text, unsigned int expectedNofItems);

std::vector<unsigned int> SplitUInt(const std::string& text, unsigned int expectedNofItems);

std::string MergeString(const std::vector<std::string>& items, const std::string& separator = " ");

std::string MergeUInt(const std::vector<unsigned int>& items, const std::string& separator = " ");

#endif
