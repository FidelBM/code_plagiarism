int main ( int argc, char * const argv[ ] )
{
	vector<GroupOfGooglers> vectorOfGroupOfGooglers;
	std::ifstream inputfile("B-small-attempt0.in");
	
	if (inputfile.is_open() )
	{
		std::string firstLine;
		getline ( inputfile, firstLine );
		
		int testCaseCount = atoi( firstLine.c_str() );

		for (int count = 0; count < testCaseCount ; count++)
		{
			std::string line;
			int numberOfGooglers;
			int numberOfSurprises;
			int p;
			vector<int> setOfResults;
			
			getline ( inputfile, line );
			
			std::string buf; // Have a buffer string
			std::stringstream ss(line); // Insert the string into a stream
			
			std::vector<std::string> tokens; // Create vector to hold our words
			
			while( ss >> buf )
			{
				tokens.push_back(buf);
			}

			numberOfGooglers = atoi ( (tokens[0 ]).c_str() );
			numberOfSurprises = atoi ( (tokens[1]).c_str() );
			p = atoi ( (tokens[2]).c_str() );

			while ( tokens.size( ) > 3 )
			{
				setOfResults.push_back( atoi ( (tokens.back( )).c_str() ) );
				tokens.pop_back( );
			}
			
			GroupOfGooglers grp( setOfResults, numberOfSurprises, p );
			int retValue = grp.Solve();
			WriteToFile( retValue, (count+1) );
			
			//write new line of this is not the last line
			if( (count + 1) != testCaseCount  )
			{
				WriteToFile("\n");
			}
		}
		inputfile.close();
	}
	else 
	{	
		std::cout << "Unable to open file";
	}
	
	return 0;
}
