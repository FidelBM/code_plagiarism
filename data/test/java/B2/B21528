import java.io.*;
class Recycled
{
public static void main(String args[])throws IOException
{
BufferedReader x=new BufferedReader(new InputStreamReader(System.in));
int t=Integer.parseInt(x.readLine());
long c[]=new long[t];
for(int i=0;i<t;i++)
{
c[i]=0;
long a=0,b=0;
String q=x.readLine();
for(int j=0;j<q.length();j++)
if(q.charAt(j)==' ')
{
a=Long.parseLong(q.substring(0,j));
b=Long.parseLong(q.substring(j+1));
break;
}
for(long j=a;j<=b;j++)
{
String s=""+j;
long y;
do{
s=s.charAt(s.length()-1)+s.substring(0,s.length()-1);
y=Long.parseLong(s);
if(y>j&&y<=b)
c[i]++;
}
while(y!=j);
}
}
for(int i=0;i<t;i++)
System.out.println("Case #"+(i+1)+": "+c[i]);
}}


