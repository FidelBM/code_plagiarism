	public static Set<Integer> recycles(int in) {
		String s = in+"";
		int l = s.length();
		Set<Integer> out = new HashSet<Integer>();
		for(int i=1;i<l;i++) {
			String n = "";
			for(int j=0;j<l;j++) n += s.charAt((i+j)%l);
			out.add(Integer.parseInt(n));
		}
		return out;
	}
	
	public static void main(String[] args) throws NumberFormatException, IOException {
		BufferedReader in = new BufferedReader(new InputStreamReader(System.in));
		
		int cases = Integer.parseInt(in.readLine());
		for (int i = 1; i <= cases; i++) {
			String[]e = in.readLine().trim().split(" ");
			int A = Integer.parseInt(e[0]);
			int B = Integer.parseInt(e[1]);
			
			int count = 0;
			
			for(int x=A;x<B;x++) {
				for(int y:recycles(x)) {
					if(x<y && y<=B) count ++;
				}
			}
			
			System.out.println("Case #"+i+": "+count);
		}
	}
	
}
