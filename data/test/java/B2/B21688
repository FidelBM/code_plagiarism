import java.io.BufferedWriter;
import java.io.File;
import java.io.FileNotFoundException;
import java.io.FileWriter;
import java.util.LinkedList;
import java.util.Scanner;

public class RecycledNumbers {

	public static int[] getM(int n) {
		String s = n + "";
		LinkedList<Integer> M = new LinkedList<Integer>();
		for (int i = 1; i < s.length(); i++) {
			boolean flag = false;
			String temp = "";
			temp = s.substring(s.length() - i, s.length()) + s;
			int t = Integer.parseInt(temp.substring(0, s.length()));
			for (int k = 0; k < M.size(); k++) {
				if (t == M.get(k)) {
					flag = true;
					break;
				}
			}
			if (!flag)
				M.add(t);
		}
		int res[] = new int[M.size()];
		for (int i = 0; i < M.size(); i++) {
			res[i] = M.get(i);
		}
		return res;
	}

	public static void main(String[] args) throws FileNotFoundException {
		Scanner in = new Scanner(new File("C-large.in"));
		// Scanner in = new Scanner(System.in);
		BufferedWriter out = null;
		try {
			FileWriter fstream = new FileWriter("out.txt");
			out = new BufferedWriter(fstream);
			int cases = in.nextInt();
			int A;
			int B;
			for (int i = 0; i < cases; i++) {
				int result = 0;
				A = in.nextInt();
				B = in.nextInt();
				for (int j = A; j < B + 1; j++) {
					int[] Ms = getM(j);
					for (int k = 0; k < Ms.length; k++) {
						if (Ms[k] > j && Ms[k] <= B) {
							result++;
						}
					}
				}
				out.write("Case #" + (i + 1) + ": " + result + "\n");
				System.out.println("Case #" + (i + 1) + ": " + result);
			}
			out.close();
		} catch (Exception e) {// Catch exception if any
			System.err.println("Error: " + e.getMessage());
		}

	}
}
