import java.util.HashSet;
import java.util.Scanner;
import java.util.Set;

public class C {

	/**
	 * @param args
	 */
	public static void main(String[] args) {
		Scanner in = new Scanner(System.in);
		Set<String> recycled = new HashSet<String>();
		
		int T = in.nextInt();

		in.nextLine();

		for (int i = 1; i <= T; i++) {
			int A = in.nextInt();
			int B = in.nextInt();
			int res = 0;
			String n1,n2,n3;
			
			for (int j = A; j <= (B - 1); j++) {
				String n = Integer.toString(j);
				for (int k = 1; k<n.length(); k++){
					n1 = n.substring(k);
					n2 = n.substring(0, k);
					n3 = n1+n2;
					if (Integer.parseInt(n3) > j && Integer.parseInt(n3) <= B && !recycled.contains(n3)){
						recycled.add(n3);
						res++;
					}
				}
				recycled.clear();
			}
			
			System.out.println("Case #"+i+": "+res);
		}

	}
	
