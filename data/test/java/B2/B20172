import java.io.BufferedReader;
import java.io.InputStreamReader;
import java.util.StringTokenizer;
class process implements Runnable {
	Thread t;
	long a=0,b=0;
	long res=0;
	int len,c=0;
	String str="";
	process(int i,long a1,long a2) {
		c=(i+1);
		a=a1;
		b=a2;
		len=String.valueOf(a).length();
		t = new Thread(this);
		t.run();
	}

	public void run() {
		
		for(long i=a;i<=b;++i)
		{
			long temp1=i;
			int temp2=0;
			int temp_len=0;
			for(int j=1;j<len;++j)
			{
					temp2=(int) (temp1%10);
					temp1=temp1/10;
					temp1=(long) ((temp2*Math.pow(10, len-1))+temp1);
					temp_len=String.valueOf(temp1).length();
					if(temp1>i && temp1<=b && (temp_len==len))//if(temp1>i && temp1<=b)
					{	
						res++;
						//System.out.println(i+"\t"+temp1);
					}
					if(temp1==i)
						break;
				
			}
		}
		
	}
	public void print()
	{
		System.out.println("Case #"+c+": "+res);
		
	}

}

public class Main {
	public static void main(String[] args) throws Exception {
		StringTokenizer st;
		BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
		int t=Integer.parseInt(br.readLine());
		process[] pr=new process[t];
		for(int i=0;i<t;++i)
		{
			st=new StringTokenizer(br.readLine());	
			pr[i]=new process(i,Long.parseLong(st.nextToken()),Long.parseLong(st.nextToken()));
		}

		for(int i=0;i<t;++i)
		{
			pr[i].t.join();
			pr[i].print();
		}
		
		
	}
}
